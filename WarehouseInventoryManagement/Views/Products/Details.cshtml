@model Inventory.Contracts.Responses.ProductResponse
@{
    ViewData["Title"] = "Product Details";
}

<div class="container">
    <h2>Product Details: @Model.Name</h2>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">SKU</dt>
        <dd class="col-sm-9">@Model.SKU</dd>

        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9">@Model.Description</dd>

        @* REMOVED: Price section to resolve CS1061 error *@

        <dt class="col-sm-3">Alert Threshold</dt>
        <dd class="col-sm-9">@Model.LowStockThreshold</dd>

        <dt class="col-sm-3">Total Stock Available</dt>
        <dd class="col-sm-9">@Model.TotalAvailableQuantity</dd>
    </dl>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>