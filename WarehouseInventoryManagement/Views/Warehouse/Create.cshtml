@using Inventory.Contracts.Requests.Warehouses
@model CreateWarehouseRequest
@{
    ViewData["Title"] = "Add New Warehouse";
    Layout = "_Layout";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
    body, .form-root { font-family: 'Plus Jakarta Sans', sans-serif; }

    .form-root { background: #f0f2f7; min-height: 100vh; padding: 2rem 1.5rem; }

    .page-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #1a56a0 100%);
        border-radius: 20px; padding: 2rem 2.5rem; margin-bottom: 2rem;
        display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    }
    .page-hero-text h1 { color: #fff; font-size: 1.6rem; font-weight: 800; margin: 0 0 .3rem; }
    .page-hero-text p  { color: rgba(255,255,255,.55); font-size: .875rem; margin: 0; }

    .page-hero-icon {
        width: 72px; height: 72px; background: rgba(255,255,255,.1);
        border: 1.5px solid rgba(255,255,255,.15); border-radius: 20px;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .page-hero-icon svg { width: 36px; height: 36px; }

    .form-card { background: #fff; border-radius: 20px; box-shadow: 0 2px 12px rgba(0,0,0,.07); max-width: 560px; margin: 0 auto; overflow: hidden; }
    .form-card-header { padding: 1.5rem 2rem; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; gap: .75rem; }
    .form-card-header svg { width: 22px; height: 22px; flex-shrink: 0; }
    .form-card-header h2 { font-size: 1rem; font-weight: 700; color: #0f172a; margin: 0; }
    .form-card-body { padding: 2rem; }

    .field-wrap { margin-bottom: 1.25rem; }
    .field-label { font-size: .75rem; font-weight: 700; letter-spacing: .5px; text-transform: uppercase; color: #64748b; margin-bottom: .45rem; display: block; }

    .field-input {
        width: 100%; padding: .72rem 1rem; border: 1.5px solid #e2e8f0; border-radius: 12px;
        font-size: .9rem; font-family: inherit; color: #0f172a; background: #f8fafc;
        transition: border-color .15s, box-shadow .15s; outline: none; box-sizing: border-box;
    }
    .field-input:focus { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,.12); background: #fff; }
    .field-error { color: #ef4444; font-size: .76rem; margin-top: .3rem; display: block; }

    .validation-summary-errors {
        background: #fff1f2; border-left: 3px solid #ef4444; border-radius: 10px;
        padding: .75rem 1rem; color: #991b1b; font-size: .82rem; margin-bottom: 1.25rem;
    }

    .form-actions { display: flex; justify-content: space-between; align-items: center; margin-top: 2rem; gap: .6rem; }

    .btn-submit {
        padding: .75rem 1.75rem; background: linear-gradient(135deg, #1e3a5f, #1a56a0); color: #fff; border: none;
        border-radius: 14px; font-size: .9rem; font-weight: 700; font-family: inherit;
        cursor: pointer; transition: all .15s; display: inline-flex; align-items: center; gap: .5rem;
    }
    .btn-submit:hover { filter: brightness(1.1); transform: translateY(-1px); }

    .btn-cancel {
        padding: .75rem 1.5rem; background: transparent; color: #64748b; border: 1.5px solid #e2e8f0;
        border-radius: 14px; font-size: .875rem; font-weight: 600; font-family: inherit;
        cursor: pointer; text-decoration: none; transition: all .15s; display: inline-flex; align-items: center; gap: .4rem;
    }
    .btn-cancel:hover { background: #f8fafc; color: #0f172a; text-decoration: none; }
</style>

<div class="form-root">
    <div class="page-hero">
        <div class="page-hero-text">
            <h1>Register New Warehouse</h1>
            <p>Add a new storage location to your warehouse network</p>
        </div>
        <div class="page-hero-icon">
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 14 L18 4 L33 14 V32 H3 Z" stroke="#fff" stroke-width="1.8" stroke-linejoin="round"/>
                <rect x="12" y="20" width="12" height="12" rx="1" stroke="#fff" stroke-width="1.8"/>
                <line x1="18" y1="8" x2="18" y2="14" stroke="rgba(255,255,255,.5)" stroke-width="1.6" stroke-linecap="round"/>
                <line x1="15" y1="11" x2="21" y2="11" stroke="rgba(255,255,255,.5)" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
        </div>
    </div>

    <div class="form-card">
        <div class="form-card-header">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="#0f172a" stroke-width="1.8" stroke-linejoin="round"/>
                <rect x="9" y="14" width="6" height="8" rx="1" stroke="#0f172a" stroke-width="1.8"/>
            </svg>
            <h2>Warehouse Details</h2>
        </div>

        <div class="form-card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                <div class="field-wrap">
                    <label asp-for="Name" class="field-label">Warehouse Name</label>
                    <input asp-for="Name" class="field-input" placeholder="e.g. Central Hub" />
                    <span asp-validation-for="Name" class="field-error"></span>
                </div>

                <div class="field-wrap">
                    <label asp-for="Location" class="field-label">Location / Address</label>
                    <input asp-for="Location" class="field-input" placeholder="e.g. New York, NY" />
                    <span asp-validation-for="Location" class="field-error"></span>
                </div>

                <div class="form-actions">
                    <a asp-action="Index" class="btn-cancel">
                        <svg viewBox="0 0 16 16" width="13" height="13" fill="none"><path d="M10 3L5 8l5 5" stroke="#64748b" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Back to List
                    </a>
                    <button type="submit" class="btn-submit">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="none"><path d="M2 8l4 4 8-8" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Save Warehouse
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}