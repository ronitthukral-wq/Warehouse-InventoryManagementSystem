@model IEnumerable<WarehouseResponse>
@{
    ViewData["Title"] = "Warehouses";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
    body, .page-root { font-family: 'Plus Jakarta Sans', sans-serif; }

    .page-root { background: #f0f2f7; min-height: 100vh; padding: 2rem 1.5rem; }

    .page-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #1a56a0 100%);
        border-radius: 20px; padding: 2rem 2.5rem; margin-bottom: 2rem;
        display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;
    }
    .page-hero-text h1 { color: #fff; font-size: 1.6rem; font-weight: 800; margin: 0 0 .3rem; }
    .page-hero-text p  { color: rgba(255,255,255,.55); font-size: .875rem; margin: 0; }

    .btn-hero-white {
        padding: .6rem 1.4rem; border-radius: 12px; font-weight: 600; font-size: .875rem;
        background: #fff; color: #0f172a; border: none; text-decoration: none;
        display: inline-flex; align-items: center; gap: .4rem; transition: transform .15s;
        box-shadow: 0 4px 14px rgba(0,0,0,.15);
    }
    .btn-hero-white:hover { transform: translateY(-2px); text-decoration: none; color: #0f172a; }

    .wh-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
    @@media (max-width: 992px) { .wh-grid { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 600px)  { .wh-grid { grid-template-columns: 1fr; } }

    .wh-card {
        background: #fff; border-radius: 20px; box-shadow: 0 2px 12px rgba(0,0,0,.06);
        overflow: hidden; transition: transform .15s, box-shadow .15s;
        display: flex; flex-direction: column;
    }
    .wh-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,.1); }

    .wh-card-top {
        background: linear-gradient(135deg, #0f172a, #1e3a5f);
        padding: 1.75rem 1.75rem 1.25rem;
        position: relative; overflow: hidden;
    }
    .wh-card-top::after {
        content: '';
        position: absolute; bottom: -1px; left: 0; right: 0;
        height: 20px; background: #fff; border-radius: 20px 20px 0 0;
    }

    .wh-icon {
        width: 48px; height: 48px; background: rgba(255,255,255,.12);
        border: 1.5px solid rgba(255,255,255,.18); border-radius: 14px;
        display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;
    }
    .wh-icon svg { width: 24px; height: 24px; }

    .wh-name { color: #fff; font-size: 1.1rem; font-weight: 800; margin: 0 0 .2rem; }

    .wh-card-body { padding: 1.25rem 1.75rem; flex: 1; display: flex; flex-direction: column; gap: .75rem; }

    .wh-location {
        display: flex; align-items: center; gap: .5rem;
        font-size: .85rem; color: #64748b; font-weight: 500;
    }
    .wh-location svg { width: 15px; height: 15px; flex-shrink: 0; }

    .wh-card-footer {
        padding: 1rem 1.75rem; border-top: 1px solid #f1f5f9;
        display: flex; justify-content: flex-end;
    }

    .btn-edit {
        display: inline-flex; align-items: center; gap: .35rem;
        padding: .45rem 1rem; border-radius: 10px; font-size: .8rem; font-weight: 700;
        background: #fef3c7; color: #92400e; text-decoration: none; transition: all .12s;
    }
    .btn-edit:hover { filter: brightness(1.05); transform: translateY(-1px); text-decoration: none; color: #92400e; }
    .btn-edit svg { width: 13px; height: 13px; }

    .empty-state {
        text-align: center; padding: 5rem 2rem; background: #fff;
        border-radius: 20px; box-shadow: 0 2px 12px rgba(0,0,0,.06); color: #94a3b8;
    }
    .empty-state svg { width: 72px; height: 72px; margin-bottom: 1rem; opacity: .4; }
    .empty-state h3 { font-size: 1rem; font-weight: 700; color: #64748b; margin: 0 0 .4rem; }
    .empty-state p  { font-size: .875rem; margin: 0 0 1.5rem; }

    .btn-add-first {
        display: inline-flex; align-items: center; gap: .4rem;
        padding: .65rem 1.5rem; background: #0f172a; color: #fff;
        border-radius: 12px; font-size: .875rem; font-weight: 700;
        text-decoration: none; transition: all .15s;
    }
    .btn-add-first:hover { filter: brightness(1.15); transform: translateY(-1px); text-decoration: none; color: #fff; }
</style>

<div class="page-root">
    <div class="page-hero">
        <div class="page-hero-text">
            <h1>Warehouses</h1>
            <p>Monitor and manage all storage locations across your network</p>
        </div>
        <a asp-action="Create" class="btn-hero-white">
            <svg viewBox="0 0 16 16" width="13" height="13" fill="none"><path d="M8 1v14M1 8h14" stroke="#0f172a" stroke-width="2.2" stroke-linecap="round"/></svg>
            Add New Warehouse
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="#cbd5e1" stroke-width="1.6" stroke-linejoin="round"/>
                <rect x="9" y="14" width="6" height="8" rx="1" stroke="#cbd5e1" stroke-width="1.6"/>
            </svg>
            <h3>No Warehouses Yet</h3>
            <p>Add your first warehouse to get started.</p>
            <a asp-action="Create" class="btn-add-first">
                <svg viewBox="0 0 16 16" width="13" height="13" fill="none"><path d="M8 1v14M1 8h14" stroke="#fff" stroke-width="2.2" stroke-linecap="round"/></svg>
                Add New Warehouse
            </a>
        </div>
    }
    else
    {
        <div class="wh-grid">
            @foreach (var warehouse in Model)
            {
                <div class="wh-card">
                    <div class="wh-card-top">
                        <div class="wh-icon">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="#fff" stroke-width="1.8" stroke-linejoin="round"/>
                                <rect x="9" y="14" width="6" height="8" rx="1" stroke="#fff" stroke-width="1.8"/>
                            </svg>
                        </div>
                        <div class="wh-name">@warehouse.Name</div>
                    </div>
                    <div class="wh-card-body">
                        <div class="wh-location">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" stroke="#94a3b8" stroke-width="1.8" stroke-linejoin="round"/>
                                <circle cx="12" cy="10" r="3" stroke="#94a3b8" stroke-width="1.8"/>
                            </svg>
                            @warehouse.Location
                        </div>
                    </div>
                    <div class="wh-card-footer">
                        <a asp-action="Edit" asp-route-id="@warehouse.Id" class="btn-edit">
                            <svg viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M9 2l3 3L4 13H1v-3L9 2z" stroke="#92400e" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            Edit
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>