@model IEnumerable<WarehouseResponse>
@{
    ViewData["Title"] = "Warehouses";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
    body, .dashboard-root { font-family: 'Plus Jakarta Sans', sans-serif; }
    .dashboard-root { background: #f0f2f7; min-height: 100vh; padding: 2rem 1.5rem; }
    .summary-chip { background: #fff; border-radius: 12px; padding: .7rem 1.1rem; font-size: .82rem; font-weight: 700; display: flex; align-items: center; gap: .5rem; box-shadow: 0 10px 28px rgba(15, 23, 42, .08); border: 1px solid rgba(148,163,184,.15); }
    .chip-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .chip-healthy { background: #f0fdf4; color: #166534; }
    .chip-out { background: #fff1f2; color: #b91c1c; }
    .chip-healthy .chip-dot { background: #16a34a; box-shadow: 0 0 0 3px rgba(22,163,74,.12); }
    .chip-out .chip-dot { background: #dc2626; box-shadow: 0 0 0 3px rgba(220,38,38,.12); }
    .hero-banner { background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #1a56a0 100%); border-radius: 24px; padding: 2.5rem; margin-bottom: 2rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
    .hero-text h1 { color: #fff; font-size: 2rem; font-weight: 800; margin: 0 0 .35rem; }
    .hero-text p { color: rgba(255,255,255,.6); margin: 0; font-size: .95rem; }
    .btn-hero { padding: .6rem 1.4rem; border-radius: 12px; font-weight: 600; font-size: .875rem; text-decoration: none; display: inline-flex; align-items: center; gap: .4rem; transition: transform .15s; background: #fff; color: #0f172a; box-shadow: 0 4px 16px rgba(0,0,0,.2); }
    .btn-hero:hover { transform: translateY(-2px); text-decoration: none; color: #0f172a; }
    .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
    @@media (max-width: 992px) { .grid { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 600px) { .grid { grid-template-columns: 1fr; } }
    .card { background: #fff; border-radius: 20px; box-shadow: 0 2px 12px rgba(0,0,0,.06); overflow: hidden; }
    .card-top { background: linear-gradient(135deg, #0f172a, #1e3a5f); padding: 1.5rem 1.75rem; }
    .card-name { color: #fff; font-size: 1.1rem; font-weight: 800; margin: 0; }
    .card-body { padding: 1.25rem 1.75rem; color: #64748b; font-size: .85rem; }
    .card-footer { padding: 1rem 1.75rem; border-top: 1px solid #f1f5f9; display: flex; justify-content: space-between; gap: .5rem; }
    .btn-edit, .btn-delete { display: inline-flex; align-items: center; gap: .35rem; padding: .45rem 1rem; border-radius: 10px; font-size: .8rem; font-weight: 700; text-decoration: none; transition: all .12s; border: none; cursor: pointer; }
    .btn-edit:hover, .btn-delete:hover { transform: translateY(-1px); text-decoration: none; }
    .btn-edit { background: #fef3c7; color: #92400e; } .btn-delete { background: #fee2e2; color: #991b1b; }

    #delete-warehouse-modal {
        display: none;
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        width: 100vw !important;
        height: 100vh !important;
        background: rgba(15, 23, 42, 0.85) !important;
        z-index: 999999 !important;
        align-items: center !important;
        justify-content: center !important;
        padding: 1rem;
    }
    #delete-warehouse-modal.show {
        display: flex !important;
    }
    #delete-warehouse-modal .modal-card {
        width: 100%;
        max-width: 440px;
        background: #ffffff !important;
        border-radius: 20px;
        box-shadow: 0 28px 90px rgba(0, 0, 0, 0.5);
        overflow: hidden;
    }
    #delete-warehouse-modal .modal-head {
        padding: 1.25rem 1.5rem;
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
        color: #fff;
    }
    #delete-warehouse-modal .modal-head h3 { margin: 0; font-size: 1rem; font-weight: 800; }
    #delete-warehouse-modal .modal-body {
        padding: 1.25rem 1.5rem;
        color: #334155;
        font-size: .9rem;
        line-height: 1.6;
        background: #fff !important;
    }
    #delete-warehouse-modal .modal-actions {
        display: flex;
        gap: .75rem;
        justify-content: flex-end;
        padding: 0 1.5rem 1.5rem;
        background: #fff !important;
    }
    #delete-warehouse-modal .modal-btn {
        border: none;
        border-radius: 12px;
        padding: .65rem 1.25rem;
        font-size: .875rem;
        font-weight: 700;
        cursor: pointer;
        font-family: inherit;
        transition: all .15s;
    }
    #delete-warehouse-modal .modal-btn-cancel { background: #f1f5f9; color: #0f172a; }
    #delete-warehouse-modal .modal-btn-cancel:hover { background: #e2e8f0; }
    #delete-warehouse-modal .modal-btn-danger { background: #ef4444; color: #fff; box-shadow: 0 4px 12px rgba(239,68,68,.4); }
    #delete-warehouse-modal .modal-btn-danger:hover { background: #dc2626; }
</style>

<div class="dashboard-root">
    @if (TempData["Success"] != null)
    {
        <div class="summary-chip chip-healthy" style="margin-bottom:1rem;">
            <span class="chip-dot"></span>@TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="summary-chip chip-out" style="margin-bottom:1rem;">
            <span class="chip-dot"></span>@TempData["Error"]
        </div>
    }

    <div class="hero-banner">
        <div class="hero-text">
            <h1>Warehouses</h1>
            <p>Monitor and manage all storage locations across your network</p>
        </div>
        <a asp-action="Create" class="btn-hero">Add New Warehouse</a>
    </div>

    <div class="grid">
        @foreach (var warehouse in Model)
        {
            <div class="card">
                <div class="card-top">
                    <div class="card-name">@warehouse.Name</div>
                </div>
                <div class="card-body">
                    @warehouse.Location
                </div>
                <div class="card-footer">
                    <a asp-action="Edit" asp-route-id="@warehouse.Id" class="btn-edit">Edit</a>
                    <button type="button" class="btn-delete" onclick="confirmDeleteWarehouse(@warehouse.Id, '@warehouse.Name')">Delete</button>
                </div>
            </div>
        }
    </div>
</div>

<form id="delete-warehouse-form" asp-action="Delete" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="delete-warehouse-id" />
</form>

<div id="delete-warehouse-modal" onclick="if(event.target===this) closeDeleteWarehouseModal()">
    <div class="modal-card">
        <div class="modal-head"><h3>🗑️ Delete warehouse</h3></div>
        <div class="modal-body">Delete <strong id="delete-warehouse-name"></strong>? This action cannot be undone.</div>
        <div class="modal-actions">
            <button type="button" class="modal-btn modal-btn-cancel" onclick="closeDeleteWarehouseModal()">Cancel</button>
            <button type="button" class="modal-btn modal-btn-danger" onclick="document.getElementById('delete-warehouse-form').submit()">Delete</button>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var modal = document.getElementById('delete-warehouse-modal');
        document.body.appendChild(modal);
    });

    function confirmDeleteWarehouse(id, name) {
        document.getElementById('delete-warehouse-id').value = id;
        document.getElementById('delete-warehouse-name').textContent = name;
        document.getElementById('delete-warehouse-modal').classList.add('show');
        document.body.style.overflow = 'hidden';
    }

    function closeDeleteWarehouseModal() {
        document.getElementById('delete-warehouse-modal').classList.remove('show');
        document.body.style.overflow = '';
    }
</script>