@model IEnumerable<WarehouseResponse>
@{
    ViewData["Title"] = "Warehouses";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
    body, .dashboard-root { font-family: 'Plus Jakarta Sans', sans-serif; }
    .dashboard-root { background: #f0f2f7; min-height: 100vh; padding: 2rem 1.5rem; }
    .grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.25rem; }
    @@media (max-width:992px) { .grid { grid-template-columns: repeat(2,1fr); } }
    @@media (max-width:600px) { .grid { grid-template-columns: 1fr; } }
    .card { background: #fff; border-radius: 20px; box-shadow: 0 2px 12px rgba(0,0,0,.06); overflow: hidden; display: flex; flex-direction: column; }
    .card-top { background: linear-gradient(135deg,#0f172a,#1e3a5f); padding: 1.5rem 1.75rem; }
    .card-name { color: #fff; font-size: 1.1rem; font-weight: 800; margin: 0 0 .3rem; }
    .card-location { color: rgba(255,255,255,.55); font-size: .8rem; margin: 0; display: flex; align-items: center; gap: .35rem; }
    .card-body { padding: 1rem 1.75rem; flex: 1; }
    .card-stat { display: flex; align-items: center; gap: .5rem; font-size: .82rem; color: #64748b; font-weight: 600; }
    .card-stat svg { width: 14px; height: 14px; flex-shrink: 0; }
    .card-footer { padding: 1rem 1.75rem; border-top: 1px solid #f1f5f9; display: flex; justify-content: space-between; gap: .5rem; flex-wrap: wrap; }
    .btn-details, .btn-edit, .btn-delete {
        display: inline-flex; align-items: center; gap: .35rem;
        padding: .45rem 1rem; border-radius: 10px; font-size: .8rem;
        font-weight: 700; text-decoration: none; transition: all .12s;
        border: none; cursor: pointer;
    }
    .btn-details, .btn-edit, .btn-delete { text-decoration: none; }
    .btn-details:hover, .btn-edit:hover, .btn-delete:hover { transform: translateY(-1px); text-decoration: none; }
    .btn-details { background: #dbeafe; color: #1e40af; }
    .btn-edit    { background: #fef3c7; color: #92400e; }
    .btn-delete  { background: #fee2e2; color: #991b1b; }
    .empty-state { text-align: center; padding: 4rem 2rem; color: #94a3b8; }
    .empty-state svg { width: 64px; height: 64px; margin-bottom: 1rem; opacity: .4; }
    .empty-state p { font-size: .9rem; margin: 0; }
</style>

<div class="dashboard-root">

    @await Component.InvokeAsync("AlertToast")

    @await Component.InvokeAsync("HeroBanner", new {
        title = "Warehouses",
        subtitle = "Monitor and manage all storage locations across your network",
        primaryButtonText = "Add New Warehouse",
        primaryButtonUrl = Url.Action("Create", "Warehouse")
    })

    @if (!Model.Any())
    {
        <div style="background:#fff;border-radius:20px;box-shadow:0 2px 12px rgba(0,0,0,.06);">
            <div class="empty-state">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="#cbd5e1" stroke-width="1.5" stroke-linejoin="round"/>
                    <polyline points="9 22 9 12 15 12 15 22" stroke="#cbd5e1" stroke-width="1.5" stroke-linejoin="round"/>
                </svg>
                <p>No warehouses registered yet. Add your first warehouse above.</p>
            </div>
        </div>
    }
    else
    {
        <div class="grid">
            @foreach (var warehouse in Model)
            {
                <div class="card">
                    <div class="card-top">
                        <p class="card-name">@warehouse.Name</p>
                        <p class="card-location">
                            <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M8 1.5A4.5 4.5 0 0 1 12.5 6c0 3-4.5 8.5-4.5 8.5S3.5 9 3.5 6A4.5 4.5 0 0 1 8 1.5Z" stroke="rgba(255,255,255,.5)" stroke-width="1.4" stroke-linejoin="round"/>
                                <circle cx="8" cy="6" r="1.5" stroke="rgba(255,255,255,.5)" stroke-width="1.4"/>
                            </svg>
                            @warehouse.Location
                        </p>
                    </div>
                    <div class="card-body">
                        <div class="card-stat">
                            <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <rect x="1" y="4" width="14" height="10" rx="1.5" stroke="#94a3b8" stroke-width="1.4"/>
                                <path d="M5 4V3a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v1" stroke="#94a3b8" stroke-width="1.4" stroke-linecap="round"/>
                            </svg>
                            Click "View Details" to see stock levels
                        </div>
                    </div>
                    <div class="card-footer">
                        <a asp-action="Details" asp-route-id="@warehouse.Id" class="btn-details">
                            <svg viewBox="0 0 14 14" width="12" height="12" fill="none"><circle cx="7" cy="7" r="5.5" stroke="#1e40af" stroke-width="1.5"/><path d="M7 6v4M7 4.5v.5" stroke="#1e40af" stroke-width="1.5" stroke-linecap="round"/></svg>
                            View Details
                        </a>
                        <div style="display:flex;gap:.5rem;">
                            <a asp-action="Edit" asp-route-id="@warehouse.Id" class="btn-edit">Edit</a>
                            <button type="button" class="btn-delete"
                                    onclick="openDeleteModal('delete-warehouse-modal','delete-warehouse-id','delete-warehouse-name',@warehouse.Id,'@warehouse.Name')">
                                Delete
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<form id="delete-warehouse-form" asp-action="Delete" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="delete-warehouse-id" />
</form>

@await Component.InvokeAsync("DeleteConfirmModal", new {
    modalId       = "delete-warehouse-modal",
    formId        = "delete-warehouse-form",
    title         = "Delete warehouse",
    nameElementId = "delete-warehouse-name"
})

<script>
    function openDeleteModal(modalId, inputId, nameId, id, name) {
        document.getElementById(inputId).value = id;
        document.getElementById(nameId).textContent = name;
        document.getElementById(modalId).classList.add('show');
        document.body.style.overflow = 'hidden';
    }
</script>