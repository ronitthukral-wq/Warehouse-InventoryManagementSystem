@using Inventory.Contracts.Responses
@model (WarehouseResponse Warehouse, List<StockLevelResponse> Stock)
@{
    ViewData["Title"] = Model.Warehouse.Name + " — Details";
    var stock      = Model.Stock ?? new List<StockLevelResponse>();
    var total      = stock.Count;
    var healthy    = stock.Count(s => !s.IsLowStock && s.Quantity > 0);
    var low        = stock.Count(s => s.IsLowStock && s.Quantity > 0);
    var outOfStock = stock.Count(s => s.Quantity == 0 && s.LowStockThreshold > 0);
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
    body, .page-root { font-family: 'Plus Jakarta Sans', sans-serif; }
    .page-root { background: #f0f2f7; min-height: 100vh; padding: 2rem 1.5rem; }

    /* Summary chips */
    .summary-strip { display: flex; gap: .75rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .summary-chip  { background: #fff; border-radius: 12px; padding: .65rem 1.1rem; font-size: .82rem; font-weight: 700; display: flex; align-items: center; gap: .5rem; box-shadow: 0 1px 6px rgba(0,0,0,.05); }
    .chip-dot      { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .chip-total   { color: #1e40af; }  .chip-total   .chip-dot { background: #3b82f6; }
    .chip-healthy { color: #166534; }  .chip-healthy .chip-dot { background: #22c55e; }
    .chip-low     { color: #92400e; }  .chip-low     .chip-dot { background: #f59e0b; }
    .chip-out     { color: #991b1b; }  .chip-out     .chip-dot { background: #ef4444; }

    /* Panel */
    .panel        { background: #fff; border-radius: 20px; box-shadow: 0 2px 12px rgba(0,0,0,.06); overflow: hidden; }
    .panel-header { padding: 1.25rem 1.75rem; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; justify-content: space-between; }
    .panel-title  { font-size: .95rem; font-weight: 700; color: #0f172a; margin: 0; display: flex; align-items: center; gap: .5rem; }
    .panel-title svg { width: 18px; height: 18px; }

    /* Table */
    .inv-table                { width: 100%; border-collapse: collapse; }
    .inv-table thead th       { padding: .75rem 1.75rem; font-size: .7rem; font-weight: 700; letter-spacing: .6px; text-transform: uppercase; color: #94a3b8; background: #f8fafc; border-bottom: 1px solid #f1f5f9; }
    .inv-table tbody td       { padding: .9rem 1.75rem; font-size: .875rem; color: #334155; border-bottom: 1px solid #f8fafc; vertical-align: middle; }
    .inv-table tbody tr:last-child td { border-bottom: none; }
    .inv-table tbody tr:hover td      { background: #f8fafc; }
    .inv-table tbody tr.row-out  td   { background: #fff1f2; }
    .inv-table tbody tr.row-warn td   { background: #fffbeb; }

    /* Badges */
    .badge-sku    { background: #f1f5f9; color: #64748b; border-radius: 6px; padding: .18rem .5rem; font-size: .72rem; font-weight: 600; font-family: 'Courier New', monospace; }
    .status-badge { border-radius: 8px; padding: .25rem .65rem; font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .4px; white-space: nowrap; }
    .sb-ok  { background: #dcfce7; color: #166534; }
    .sb-low { background: #fef3c7; color: #92400e; }
    .sb-out { background: #fee2e2; color: #991b1b; }

    .qty-val { font-weight: 700; }
    .qty-ok  { color: #0f172a; }
    .qty-low { color: #d97706; }
    .qty-out { color: #ef4444; }

    /* Empty */
    .empty-panel     { text-align: center; padding: 4rem 2rem; }
    .empty-panel svg { width: 72px; height: 72px; margin-bottom: 1rem; opacity: .4; }
    .empty-panel p   { font-size: .9rem; color: #94a3b8; margin: 0; }

    /* Back link in hero */
    .btn-back {
        display: inline-flex; align-items: center; gap: .45rem;
        padding: .55rem 1.2rem; border-radius: 12px; font-weight: 600; font-size: .85rem;
        background: rgba(255,255,255,.15); color: #fff;
        border: 1px solid rgba(255,255,255,.25); text-decoration: none;
        transition: background .15s;
    }
    .btn-back:hover { background: rgba(255,255,255,.25); text-decoration: none; color: #fff; }
</style>

<div class="page-root">

    @await Component.InvokeAsync("AlertToast")

    @await Component.InvokeAsync("HeroBanner", new {
        title               = Model.Warehouse.Name,
        subtitle            = "📍 " + Model.Warehouse.Location + "  •  Stock overview for this warehouse",
        secondaryButtonText = "← Back to Warehouses",
        secondaryButtonUrl  = Url.Action("Index", "Warehouse")
    })

    @if (total == 0)
    {
        <div class="panel">
            <div class="empty-panel">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z" stroke="#cbd5e1" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96" stroke="#cbd5e1" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                    <line x1="12" y1="22.08" x2="12" y2="12" stroke="#cbd5e1" stroke-width="1.6" stroke-linecap="round"/>
                </svg>
                <p>This warehouse has no stock recorded yet.</p>
            </div>
        </div>
    }
    else
    {
        <div class="summary-strip">
            <div class="summary-chip chip-total">
                <span class="chip-dot"></span> @total product@(total == 1 ? "" : "s") stocked
            </div>
            <div class="summary-chip chip-healthy">
                <span class="chip-dot"></span> @healthy healthy
            </div>
            <div class="summary-chip chip-low">
                <span class="chip-dot"></span> @low running low
            </div>
            <div class="summary-chip chip-out">
                <span class="chip-dot"></span> @outOfStock out of stock
            </div>
        </div>

        <div class="panel">
            <div class="panel-header">
                <p class="panel-title">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="3" y="3" width="7" height="7" rx="1" stroke="#475569" stroke-width="1.8"/>
                        <rect x="14" y="3" width="7" height="7" rx="1" stroke="#475569" stroke-width="1.8"/>
                        <rect x="3" y="14" width="7" height="7" rx="1" stroke="#475569" stroke-width="1.8"/>
                        <rect x="14" y="14" width="7" height="7" rx="1" stroke="#475569" stroke-width="1.8"/>
                    </svg>
                    Stock Levels
                </p>
                <span style="font-size:.75rem;color:#94a3b8;font-weight:600;">@total items</span>
            </div>

            <table class="inv-table">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>SKU</th>
                        <th style="text-align:right">Quantity</th>
                        <th style="text-align:right">Alert Threshold</th>
                        <th style="text-align:center">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in stock.OrderBy(s => s.ProductName))
                    {
                        string rowClass = item.Quantity == 0 ? "row-out"
                                        : item.IsLowStock   ? "row-warn"
                                        : "";
                        string sbClass  = item.Quantity == 0 && item.LowStockThreshold > 0 ? "sb-out"
                                        : item.IsLowStock ? "sb-low"
                                        : "sb-ok";
                        string sbLabel  = item.Quantity == 0 && item.LowStockThreshold > 0 ? "Out of Stock"
                                        : item.IsLowStock ? "Low Stock"
                                        : "Healthy";
                        string qtyClass = item.Quantity == 0 ? "qty-out"
                                        : item.IsLowStock   ? "qty-low"
                                        : "qty-ok";

                        <tr class="@rowClass">
                            <td>
                                <p asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId"
                                   style="font-weight:700;color:#0f172a;text-decoration:none;transition:color .12s;"
                                   onmouseover="this.style.color='#2563eb'" onmouseout="this.style.color='#0f172a'">
                                    @item.ProductName
                                </p>
                            </td>
                            <td><span class="badge-sku">@item.SKU</span></td>
                            <td style="text-align:right">
                                <span class="qty-val @qtyClass">@item.Quantity</span>
                            </td>
                            <td style="text-align:right;color:#94a3b8;font-size:.82rem">@item.LowStockThreshold</td>
                            <td style="text-align:center">
                                <span class="status-badge @sbClass">@sbLabel</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>