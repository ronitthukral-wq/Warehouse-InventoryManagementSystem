@if (ViewBag.Success != null)
{
    <div id="toast-success" style="background:#f0fdf4;border-left:4px solid #22c55e;border-radius:12px;padding:.9rem 1.2rem;color:#166534;font-weight:600;font-size:.9rem;margin-bottom:1.25rem;display:flex;align-items:center;justify-content:space-between;">
        <span>✓ &nbsp;@ViewBag.Success</span>
        <button onclick="document.getElementById('toast-success').style.display='none'"
                style="background:none;border:none;cursor:pointer;font-size:1.1rem;color:inherit;opacity:.6;padding:0;">
            ✕
        </button>
    </div>
}
@if (ViewBag.Error != null)
{
    <div id="toast-error" style="background:#fff1f2;border-left:4px solid #ef4444;border-radius:12px;padding:.9rem 1.2rem;color:#991b1b;font-weight:600;font-size:.9rem;margin-bottom:1.25rem;display:flex;align-items:center;justify-content:space-between;">
        <span>⚠ &nbsp;@ViewBag.Error</span>
        <button onclick="document.getElementById('toast-error').style.display='none'"
                style="background:none;border:none;cursor:pointer;font-size:1.1rem;color:inherit;opacity:.6;padding:0;">
            ✕
        </button>
    </div>
}