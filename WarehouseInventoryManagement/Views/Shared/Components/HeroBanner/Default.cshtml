<div style="background:linear-gradient(135deg,#0f172a 0%,#1e3a5f 60%,#1a56a0 100%);border-radius:24px;padding:2.5rem;margin-bottom:2rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
    <div>
        <h1 style="color:#fff;font-size:2rem;font-weight:800;margin:0 0 .35rem;letter-spacing:-.5px;">@ViewBag.Title</h1>
        <p style="color:rgba(255,255,255,.6);margin:0;font-size:.95rem;">@ViewBag.Subtitle</p>
    </div>
    @if (ViewBag.PrimaryButtonText != null || ViewBag.SecondaryButtonText != null)
    {
        <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
            @if (ViewBag.PrimaryButtonText != null)
            {
                <a href="@ViewBag.PrimaryButtonUrl"
                       style="padding:.6rem 1.4rem;border-radius:12px;font-weight:600;font-size:.875rem;background:#fff;color:#0f172a;text-decoration:none;box-shadow:0 4px 16px rgba(0,0,0,.2);display:inline-flex;align-items:center;">
                    @ViewBag.PrimaryButtonText
                </a>
            }
            @if (ViewBag.SecondaryButtonText != null)
            {
                <a href="@ViewBag.SecondaryButtonUrl"
                       style="padding:.6rem 1.4rem;border-radius:12px;font-weight:600;font-size:.875rem;background:rgba(255,255,255,.15);color:#fff;border:1px solid rgba(255,255,255,.25);text-decoration:none;display:inline-flex;align-items:center;">
                    @ViewBag.SecondaryButtonText
                </a>
            }
        </div>
    }
</div>