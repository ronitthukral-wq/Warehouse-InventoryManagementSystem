@model IEnumerable<Inventory.Contracts.Responses.ProductResponse>

@if (Model != null && Model.Any())
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>Low Stock Warning:</strong> @Model.Count() products are below their threshold.
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        <hr>
        <ul class="mb-0 small">
            @foreach (var product in Model.Take(3))
            {
                <li>ID: @product.Id is currently at @product.LowStockThreshold units.</li>
            }
        </ul>
    </div>
}