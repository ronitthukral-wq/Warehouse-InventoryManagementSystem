<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Warehouse Management</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Dashboard" asp-action="Index">IMS</a>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item"><a class="nav-link text-dark" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item"><a class="nav-link text-dark" asp-controller="Warehouse" asp-action="Index">Warehouses</a></li>
                            <li class="nav-item"><a class="nav-link text-dark" asp-controller="Product" asp-action="Index">Products</a></li>
                            <li class="nav-item"><a class="nav-link text-dark" asp-controller="User" asp-action="Index">Personnel</a></li>
                            <li class="nav-item"><a class="nav-link text-dark" asp-controller="Inventory" asp-action="PendingTransfers">All Transfers</a></li>
                            <li class="nav-item"><a class="nav-link text-dark" asp-controller="Inventory" asp-action="History">History</a></li>
                        }

                        @if (User.IsInRole("StoreManager"))
                        {
                            <li class="nav-item"><a class="nav-link text-dark" asp-controller="Inventory" asp-action="MyStock">My Inventory</a></li>
                            <li class="nav-item"><a class="nav-link text-dark" asp-controller="Product" asp-action="Index">Catalog</a></li>
                            <li class="nav-item"><a class="nav-link text-dark" asp-controller="Inventory" asp-action="AddStock">Add Stock</a></li>
                            <li class="nav-item"><a class="nav-link text-dark" asp-controller="Inventory" asp-action="RequestTransfer">Request Transfer</a></li>
                            <li class="nav-item"><a class="nav-link text-dark" asp-controller="Inventory" asp-action="PendingTransfers">Incoming</a></li>
                            <li class="nav-item"><a class="nav-link text-dark" asp-controller="Inventory" asp-action="History">History</a></li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }
            @RenderBody()
        </main>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
