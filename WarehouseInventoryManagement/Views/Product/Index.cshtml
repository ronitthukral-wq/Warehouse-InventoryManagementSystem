@model IEnumerable<ProductResponse>
@{
    ViewData["Title"] = "Products";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
    body, .page-root { font-family: 'Plus Jakarta Sans', sans-serif; }

    .page-root { background: #f0f2f7; min-height: 100vh; padding: 2rem 1.5rem; }

    .page-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #1a56a0 100%);
        border-radius: 20px; padding: 2rem 2.5rem; margin-bottom: 2rem;
        display: flex; align-items: center; justify-content: space-between;
        flex-wrap: wrap; gap: 1rem;
    }
    .page-hero-text h1 { color: #fff; font-size: 1.6rem; font-weight: 800; margin: 0 0 .3rem; }
    .page-hero-text p  { color: rgba(255,255,255,.55); font-size: .875rem; margin: 0; }

    .btn-hero-white {
        padding: .6rem 1.4rem; border-radius: 12px; font-weight: 600; font-size: .875rem;
        background: #fff; color: #0f172a; border: none; text-decoration: none;
        display: inline-flex; align-items: center; gap: .4rem; transition: transform .15s;
        box-shadow: 0 4px 14px rgba(0,0,0,.15);
    }
    .btn-hero-white:hover { transform: translateY(-2px); text-decoration: none; color: #0f172a; }

    .panel { background: #fff; border-radius: 20px; box-shadow: 0 2px 12px rgba(0,0,0,.06); overflow: hidden; }

    .panel-header {
        padding: 1.25rem 1.75rem; border-bottom: 1px solid #f1f5f9;
        display: flex; align-items: center; justify-content: space-between;
    }
    .panel-title { font-size: .95rem; font-weight: 700; color: #0f172a; margin: 0; display: flex; align-items: center; gap: .5rem; }
    .panel-title svg { width: 20px; height: 20px; }
    .panel-count { background: #f1f5f9; color: #64748b; border-radius: 20px; padding: .2rem .7rem; font-size: .75rem; font-weight: 700; }

    .prod-table { width: 100%; border-collapse: collapse; }
    .prod-table thead th {
        padding: .75rem 1.75rem; font-size: .7rem; font-weight: 700; letter-spacing: .6px;
        text-transform: uppercase; color: #94a3b8; background: #f8fafc; border-bottom: 1px solid #f1f5f9;
    }
    .prod-table tbody td {
        padding: .9rem 1.75rem; font-size: .875rem; color: #334155;
        border-bottom: 1px solid #f8fafc; vertical-align: middle;
    }
    .prod-table tbody tr:last-child td { border-bottom: none; }
    .prod-table tbody tr:hover td { background: #f8fafc; }

    .badge-sku {
        background: #f1f5f9; color: #64748b; border-radius: 6px;
        padding: .2rem .5rem; font-size: .72rem; font-weight: 600; font-family: 'Courier New', monospace;
    }

    .action-link {
        display: inline-flex; align-items: center; gap: .3rem;
        font-size: .78rem; font-weight: 600; border-radius: 8px;
        padding: .28rem .7rem; text-decoration: none; transition: all .12s;
    }
    .action-link:hover { transform: translateY(-1px); text-decoration: none; }
    .al-edit    { background: #fef3c7; color: #92400e; }
    .al-details { background: #dbeafe; color: #1e40af; }

    .empty-state { text-align: center; padding: 4rem 2rem; color: #94a3b8; }
    .empty-state svg { width: 64px; height: 64px; margin-bottom: 1rem; opacity: .45; }
    .empty-state p { font-size: .9rem; margin: 0; }
</style>

<div class="page-root">
    <div class="page-hero">
        <div class="page-hero-text">
            <h1>Product Catalog</h1>
            <p>Manage all SKUs available across your warehouse network</p>
        </div>
        <a asp-action="Create" class="btn-hero-white">
            <svg viewBox="0 0 16 16" width="13" height="13" fill="none"><path d="M8 1v14M1 8h14" stroke="#0f172a" stroke-width="2.2" stroke-linecap="round"/></svg>
            New Product
        </a>
    </div>

    <div class="panel">
        <div class="panel-header">
            <p class="panel-title">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z" stroke="#16a34a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96" stroke="#16a34a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                    <line x1="12" y1="22.08" x2="12" y2="12" stroke="#16a34a" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
                All Products
            </p>
            <span class="panel-count">@Model.Count() items</span>
        </div>

        <table class="prod-table">
            <thead>
                <tr>
                    <th>SKU</th>
                    <th>Name</th>
                    <th style="text-align:right">Alert Threshold</th>
                    <th style="text-align:right">Total Available</th>
                    <th style="text-align:right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="5">
                        <div class="empty-state">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z" stroke="#cbd5e1" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                                <polyline points="3.27 6.96 12 12.01 20.73 6.96" stroke="#cbd5e1" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                                <line x1="12" y1="22.08" x2="12" y2="12" stroke="#cbd5e1" stroke-width="1.6" stroke-linecap="round"/>
                            </svg>
                            <p>No products in the catalog yet.</p>
                        </div>
                    </td></tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="badge-sku">@item.SKU</span></td>
                        <td><strong style="color:#0f172a">@item.Name</strong></td>
                        <td style="text-align:right;color:#64748b">@item.LowStockThreshold</td>
                        <td style="text-align:right;font-weight:700;color:#0f172a">@item.TotalAvailableQuantity</td>
                        <td style="text-align:right">
                            <a asp-action="Edit"    asp-route-id="@item.Id" class="action-link al-edit">
                                <svg viewBox="0 0 14 14" width="11" height="11" fill="none"><path d="M9 2l3 3L4 13H1v-3L9 2z" stroke="#92400e" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                Edit
                            </a>
                            &nbsp;
                            <a asp-action="Details" asp-route-id="@item.Id" class="action-link al-details">
                                <svg viewBox="0 0 14 14" width="11" height="11" fill="none"><circle cx="7" cy="7" r="5.5" stroke="#1e40af" stroke-width="1.4"/><line x1="7" y1="6" x2="7" y2="10" stroke="#1e40af" stroke-width="1.4" stroke-linecap="round"/><circle cx="7" cy="4.5" r=".6" fill="#1e40af"/></svg>
                                Details
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>