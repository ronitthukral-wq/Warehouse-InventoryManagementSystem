@model IEnumerable<ProductResponse>
@{
    ViewData["Title"] = "Products";
    var total = Model?.Count() ?? 0;
    var lowCount = Model?.Count(x => x.TotalAvailableQuantity <= x.LowStockThreshold && x.TotalAvailableQuantity > 0) ?? 0;
    var outCount = Model?.Count(x => x.TotalAvailableQuantity == 0) ?? 0;
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
    body, .dashboard-root { font-family: 'Plus Jakarta Sans', sans-serif; }
    .dashboard-root { background: #f0f2f7; min-height: 100vh; padding: 2rem 1.5rem; }
    .hero-banner {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #1a56a0 100%);
        border-radius: 24px; padding: 2.5rem; margin-bottom: 2rem; position: relative; overflow: hidden;
        display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    }
    .hero-banner::before, .hero-banner::after {
        content: ''; position: absolute; border-radius: 50%; pointer-events: none;
        background: rgba(255,255,255,.04);
    }
    .hero-banner::before { width: 260px; height: 260px; top: -80px; right: -40px; }
    .hero-banner::after { width: 180px; height: 180px; bottom: -70px; left: 18%; background: rgba(255,255,255,.03); }
    .hero-text h1 { color: #fff; font-size: 2rem; font-weight: 800; margin: 0 0 .35rem; letter-spacing: -.5px; }
    .hero-text p { color: rgba(255,255,255,.6); margin: 0; font-size: .95rem; }
    .hero-actions { display: flex; gap: .75rem; flex-wrap: wrap; margin-top: 1.25rem; }
    .btn-hero { padding: .6rem 1.4rem; border-radius: 12px; font-weight: 600; font-size: .875rem; border: none; cursor: pointer; text-decoration: none; transition: transform .15s; display: inline-flex; align-items: center; gap: .4rem; }
    .btn-hero:hover { transform: translateY(-2px); text-decoration: none; }
    .btn-hero-primary { background: #fff; color: #0f172a; box-shadow: 0 4px 16px rgba(0,0,0,.2); }
    .btn-hero-secondary { background: rgba(255,255,255,.15); color: #fff; border: 1px solid rgba(255,255,255,.25); }
    .summary-strip { display: flex; gap: .75rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .summary-chip { background: #fff; border-radius: 12px; padding: .7rem 1.1rem; font-size: .82rem; font-weight: 700; display: flex; align-items: center; gap: .5rem; box-shadow: 0 10px 28px rgba(15, 23, 42, .08); border: 1px solid rgba(148,163,184,.15); }
    .chip-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .chip-total .chip-dot { background: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,.12); } .chip-total { background: #eff6ff; color: #1d4ed8; }
    .chip-low .chip-dot { background: #d97706; box-shadow: 0 0 0 3px rgba(217,119,6,.12); } .chip-low { background: #fffbeb; color: #b45309; }
    .chip-out .chip-dot { background: #dc2626; box-shadow: 0 0 0 3px rgba(220,38,38,.12); } .chip-out { background: #fff1f2; color: #b91c1c; }
    .panel { background: #fff; border-radius: 20px; box-shadow: 0 2px 12px rgba(0,0,0,.06); overflow: hidden; }
    .panel-header { padding: 1.25rem 1.75rem; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; justify-content: space-between; }
    .panel-title { font-size: .95rem; font-weight: 700; color: #0f172a; margin: 0; }
    .panel-count { background: #f1f5f9; color: #64748b; border-radius: 20px; padding: .2rem .7rem; font-size: .75rem; font-weight: 700; }
    .prod-table { width: 100%; border-collapse: collapse; }
    .prod-table thead th { padding: .75rem 1.75rem; font-size: .7rem; font-weight: 700; letter-spacing: .6px; text-transform: uppercase; color: #94a3b8; background: #f8fafc; border-bottom: 1px solid #f1f5f9; }
    .prod-table tbody td { padding: .9rem 1.75rem; font-size: .875rem; color: #334155; border-bottom: 1px solid #f8fafc; vertical-align: middle; }
    .prod-table tbody tr:hover td { background: #f8fafc; }
    .badge-sku { background: #f1f5f9; color: #64748b; border-radius: 6px; padding: .2rem .5rem; font-size: .72rem; font-weight: 600; font-family: 'Courier New', monospace; }
    .action-link { display: inline-flex; align-items: center; gap: .3rem; font-size: .78rem; font-weight: 600; border-radius: 8px; padding: .28rem .7rem; text-decoration: none; transition: all .12s; border: none; cursor: pointer; }
    .action-link:hover { transform: translateY(-1px); text-decoration: none; }
    .al-edit { background: #fef3c7; color: #92400e; } .al-details { background: #dbeafe; color: #1e40af; } .al-delete { background: #fee2e2; color: #991b1b; }

    #delete-product-modal {
        display: none;
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        width: 100vw !important;
        height: 100vh !important;
        background: rgba(15, 23, 42, 0.85) !important;
        z-index: 999999 !important;
        align-items: center !important;
        justify-content: center !important;
        padding: 1rem;
    }
    #delete-product-modal.show {
        display: flex !important;
    }
    #delete-product-modal .modal-card {
        width: 100%;
        max-width: 440px;
        background: #ffffff !important;
        border-radius: 20px;
        box-shadow: 0 28px 90px rgba(0, 0, 0, 0.5);
        overflow: hidden;
    }
    #delete-product-modal .modal-head {
        padding: 1.25rem 1.5rem;
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
        color: #fff;
    }
    #delete-product-modal .modal-head h3 { margin: 0; font-size: 1rem; font-weight: 800; }
    #delete-product-modal .modal-body {
        padding: 1.25rem 1.5rem;
        color: #334155;
        font-size: .9rem;
        line-height: 1.6;
        background: #fff !important;
    }
    #delete-product-modal .modal-actions {
        display: flex;
        gap: .75rem;
        justify-content: flex-end;
        padding: 0 1.5rem 1.5rem;
        background: #fff !important;
    }
    #delete-product-modal .modal-btn {
        border: none;
        border-radius: 12px;
        padding: .65rem 1.25rem;
        font-size: .875rem;
        font-weight: 700;
        cursor: pointer;
        font-family: inherit;
        transition: all .15s;
    }
    #delete-product-modal .modal-btn-cancel { background: #f1f5f9; color: #0f172a; }
    #delete-product-modal .modal-btn-cancel:hover { background: #e2e8f0; }
    #delete-product-modal .modal-btn-danger { background: #ef4444; color: #fff; box-shadow: 0 4px 12px rgba(239,68,68,.4); }
    #delete-product-modal .modal-btn-danger:hover { background: #dc2626; }
</style>

<div class="dashboard-root">
    @if (TempData["Success"] != null)
    {
        <div class="summary-chip chip-healthy" style="margin-bottom:1rem;">
            <span class="chip-dot"></span>@TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="summary-chip chip-out" style="margin-bottom:1rem;">
            <span class="chip-dot"></span>@TempData["Error"]
        </div>
    }

    <div class="hero-banner">
        <div class="hero-text">
            <h1>Product Catalog</h1>
            <p>Manage all SKUs available across your warehouse network</p>
            <div class="hero-actions">
                <a asp-action="Create" class="btn-hero btn-hero-primary">New Product</a>
                <a asp-action="LowStockAlerts" class="btn-hero btn-hero-secondary">Low Stock Alerts</a>
            </div>
        </div>
    </div>

    <div class="summary-strip">
        <div class="summary-chip chip-total"><span class="chip-dot"></span>@total total products</div>
        <div class="summary-chip chip-low"><span class="chip-dot"></span>@lowCount running low</div>
        <div class="summary-chip chip-out"><span class="chip-dot"></span>@outCount out of stock</div>
    </div>

    <div class="panel">
        <div class="panel-header">
            <p class="panel-title">All Products</p>
            <span class="panel-count">@total items</span>
        </div>
        <table class="prod-table">
            <thead>
                <tr>
                    <th>SKU</th>
                    <th>Name</th>
                    <th style="text-align:right">Alert Threshold</th>
                    <th style="text-align:right">Total Available</th>
                    <th style="text-align:right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="badge-sku">@item.SKU</span></td>
                        <td><strong style="color:#0f172a">@item.Name</strong></td>
                        <td style="text-align:right;color:#64748b">@item.LowStockThreshold</td>
                        <td style="text-align:right;font-weight:700;color:#0f172a">@item.TotalAvailableQuantity</td>
                        <td style="text-align:right">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="action-link al-edit">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="action-link al-details">Details</a>
                            <button type="button" class="action-link al-delete" onclick="confirmDeleteProduct(@item.Id, '@item.Name')">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<form id="delete-product-form" asp-action="Delete" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="delete-product-id" />
</form>

<div id="delete-product-modal" onclick="if(event.target===this) closeDeleteProductModal()">
    <div class="modal-card">
        <div class="modal-head"><h3>🗑️ Delete product</h3></div>
        <div class="modal-body">Delete <strong id="delete-product-name"></strong>? This action cannot be undone.</div>
        <div class="modal-actions">
            <button type="button" class="modal-btn modal-btn-cancel" onclick="closeDeleteProductModal()">Cancel</button>
            <button type="button" class="modal-btn modal-btn-danger" onclick="document.getElementById('delete-product-form').submit()">Delete</button>
        </div>
    </div>
</div>

<script>
    // Move modal to document.body to escape any parent stacking context
    document.addEventListener('DOMContentLoaded', function () {
        var modal = document.getElementById('delete-product-modal');
        document.body.appendChild(modal);
    });

    function confirmDeleteProduct(id, name) {
        document.getElementById('delete-product-id').value = id;
        document.getElementById('delete-product-name').textContent = name;
        document.getElementById('delete-product-modal').classList.add('show');
        document.body.style.overflow = 'hidden';
    }

    function closeDeleteProductModal() {
        document.getElementById('delete-product-modal').classList.remove('show');
        document.body.style.overflow = '';
    }
</script>