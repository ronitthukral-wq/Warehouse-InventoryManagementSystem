@using Inventory.Contracts.Requests.Users
@model LoginRequest
@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background: #f0f2f7;
    }

    .login-wrapper {
        min-height: 90vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }

    .login-card {
        background: #fff;
        border-radius: 24px;
        box-shadow: 0 8px 40px rgba(0,0,0,.1);
        width: 100%;
        max-width: 420px;
        overflow: hidden;
    }

    .login-header {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #1a56a0 100%);
        padding: 2.5rem 2rem 2rem;
        text-align: center;
        position: relative;
    }

        .login-header::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            right: 0;
            height: 24px;
            background: #fff;
            border-radius: 24px 24px 0 0;
        }

    .login-logo {
        width: 64px;
        height: 64px;
        background: rgba(255,255,255,.12);
        border: 1.5px solid rgba(255,255,255,.2);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
    }

        .login-logo svg {
            width: 32px;
            height: 32px;
        }

    .login-header h1 {
        color: #fff;
        font-size: 1.35rem;
        font-weight: 800;
        margin: 0 0 .25rem;
    }

    .login-header p {
        color: rgba(255,255,255,.55);
        font-size: .82rem;
        margin: 0;
    }

    .login-body {
        padding: 1.75rem 2rem 2rem;
    }

    .field-label {
        font-size: .78rem;
        font-weight: 700;
        letter-spacing: .5px;
        text-transform: uppercase;
        color: #64748b;
        margin-bottom: .45rem;
        display: block;
    }

    .field-input {
        width: 100%;
        padding: .7rem 1rem;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        font-size: .9rem;
        font-family: inherit;
        color: #0f172a;
        background: #f8fafc;
        transition: border-color .15s, box-shadow .15s;
        outline: none;
        box-sizing: border-box;
    }

        .field-input:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,.12);
            background: #fff;
        }

    .field-wrap {
        margin-bottom: 1.1rem;
    }

    .field-error {
        color: #ef4444;
        font-size: .76rem;
        margin-top: .3rem;
        display: block;
    }

    .remember-row {
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: 1.5rem;
    }

        .remember-row input[type="checkbox"] {
            width: 16px;
            height: 16px;
            accent-color: #3b82f6;
            cursor: pointer;
        }

        .remember-row label {
            font-size: .85rem;
            color: #64748b;
            cursor: pointer;
            margin: 0;
        }

    .btn-login {
        width: 100%;
        padding: .8rem 1rem;
        background: linear-gradient(135deg, #1e3a5f, #1a56a0);
        color: #fff;
        border: none;
        border-radius: 14px;
        font-size: .95rem;
        font-weight: 700;
        font-family: inherit;
        cursor: pointer;
        transition: transform .15s, box-shadow .15s;
        box-shadow: 0 4px 16px rgba(30,58,95,.3);
    }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(30,58,95,.35);
        }

    .login-hint {
        text-align: center;
        margin-top: 1.25rem;
        padding: .85rem 1rem;
        background: #f8fafc;
        border-radius: 12px;
        border: 1px dashed #e2e8f0;
    }

        .login-hint p {
            font-size: .75rem;
            color: #94a3b8;
            margin: 0;
            line-height: 1.6;
        }

        .login-hint strong {
            color: #64748b;
        }

    .validation-summary {
        background: #fff1f2;
        border-left: 3px solid #ef4444;
        border-radius: 10px;
        padding: .75rem 1rem;
        color: #991b1b;
        font-size: .82rem;
        margin-bottom: 1.25rem;
    }
</style>

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-header">
            <div class="login-logo">
                <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M16 3 L29 10 L29 22 L16 29 L3 22 L3 10 Z" stroke="#fff" stroke-width="1.8" stroke-linejoin="round" />
                    <path d="M3 10 L16 17 L29 10" stroke="#fff" stroke-width="1.8" stroke-linecap="round" />
                    <line x1="16" y1="17" x2="16" y2="29" stroke="#fff" stroke-width="1.8" stroke-linecap="round" />
                    <path d="M10 6.5 L23 13.5" stroke="rgba(255,255,255,.45)" stroke-width="1.4" stroke-linecap="round" />
                </svg>
            </div>
            <h1>Inventory Management</h1>
            <p>Sign in to your account to continue</p>
        </div>

        <div class="login-body">
            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                <div class="field-wrap">
                    <label asp-for="Email" class="field-label">Email Address</label>
                    <input asp-for="Email" class="field-input" placeholder="name@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                <div class="field-wrap">
                    <label asp-for="Password" class="field-label">Password</label>
                    <input asp-for="Password" type="password" class="field-input" placeholder="••••••••" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>

                <div class="remember-row">
                    <input asp-for="RememberMe" type="checkbox" id="RememberMe" />
                    <label asp-for="RememberMe">Remember me for 30 days</label>
                </div>

                <button type="submit" class="btn-login">Sign In</button>
            </form>

            <div class="login-hint">
                <p><strong>Default Admin</strong><br>admin@inventory.com &nbsp;/&nbsp; Admin123</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}