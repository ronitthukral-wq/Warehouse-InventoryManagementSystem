@model Inventory.Contracts.Responses.DashboardMetricsResponse
@{
    ViewData["Title"] = User.IsInRole("Admin") ? "Admin Dashboard" : "My Warehouse";
    var isAdmin = User.IsInRole("Admin");
}

<div class="container mt-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div id="success-alert" class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
            <strong>Success.</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (isAdmin)
    {
        <div class="p-5 mb-4 bg-light rounded-3 shadow-sm border">
            <div class="container-fluid py-2">
                <h1 class="display-5 fw-bold text-primary">Admin Control Panel</h1>
                <p class="col-md-8 fs-5 text-muted">Manage warehouses, the product catalog, store managers and oversee all transfers.</p>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100"><div class="card-body">
                    <p class="text-muted small mb-1">Total Products</p>
                    <h3 class="fw-bold mb-0">@Model.TotalProducts</h3>
                </div></div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100"><div class="card-body">
                    <p class="text-muted small mb-1">Total Stock Units</p>
                    <h3 class="fw-bold mb-0">@Model.TotalStockQuantity</h3>
                </div></div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100"><div class="card-body">
                    <p class="text-muted small mb-1">Low Stock Alerts</p>
                    <h3 class="fw-bold mb-0 text-warning">@Model.LowStockAlertsCount</h3>
                </div></div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm h-100"><div class="card-body">
                    <p class="text-muted small mb-1">Pending Transfers</p>
                    <h3 class="fw-bold mb-0 text-info">@Model.PendingTransfersCount</h3>
                </div></div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body text-center p-4">
                        <h3 class="card-title h4">Warehouses</h3>
                        <p class="text-muted small">Monitor and manage storage locations.</p>
                        <div class="d-grid gap-2">
                            <a asp-controller="Warehouse" asp-action="Index" class="btn btn-dark">View List</a>
                            <a asp-controller="Warehouse" asp-action="Create" class="btn btn-outline-dark">Add New Warehouse</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body text-center p-4">
                        <h3 class="card-title h4">Products</h3>
                        <p class="text-muted small">Maintain the global product catalog and SKUs.</p>
                        <div class="d-grid gap-2">
                            <a asp-controller="Product" asp-action="Index" class="btn btn-success">View Catalog</a>
                            <a asp-controller="Product" asp-action="Create" class="btn btn-outline-success">Add New SKU</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body text-center p-4">
                        <h3 class="card-title h4">Personnel</h3>
                        <p class="text-muted small">Assign exactly one store manager per warehouse.</p>
                        <div class="d-grid gap-2">
                            <a asp-controller="User" asp-action="Index" class="btn btn-info text-white">Manage Users</a>
                            <a asp-controller="User" asp-action="Create" class="btn btn-outline-info">Register Manager</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="p-5 mb-4 bg-light rounded-3 shadow-sm border">
            <div class="container-fluid py-2">
                <h1 class="display-5 fw-bold text-primary">My Warehouse</h1>
                <p class="col-md-8 fs-5 text-muted">
                    Hello @User.Identity?.Name. Manage your stock, send transfer requests, and review incoming approvals.
                </p>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100"><div class="card-body">
                    <p class="text-muted small mb-1">Stock Units (My Warehouse)</p>
                    <h3 class="fw-bold mb-0">@Model.TotalStockQuantity</h3>
                </div></div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100"><div class="card-body">
                    <p class="text-muted small mb-1">Low Stock Alerts</p>
                    <h3 class="fw-bold mb-0 text-warning">@Model.LowStockAlertsCount</h3>
                </div></div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100"><div class="card-body">
                    <p class="text-muted small mb-1">Incoming Transfers</p>
                    <h3 class="fw-bold mb-0 text-info">@Model.PendingTransfersCount</h3>
                </div></div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm"><div class="card-body text-center p-4">
                    <h3 class="card-title h5">My Inventory</h3>
                    <p class="text-muted small">View current stock levels in your warehouse.</p>
                    <a asp-controller="Inventory" asp-action="MyStock" class="btn btn-dark w-100">Open</a>
                </div></div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm"><div class="card-body text-center p-4">
                    <h3 class="card-title h5">Add Stock</h3>
                    <p class="text-muted small">Top up quantities for any product in the catalog.</p>
                    <a asp-controller="Inventory" asp-action="AddStock" class="btn btn-success w-100">Add</a>
                </div></div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm"><div class="card-body text-center p-4">
                    <h3 class="card-title h5">Request Transfer</h3>
                    <p class="text-muted small">Send stock from your warehouse to another.</p>
                    <a asp-controller="Inventory" asp-action="RequestTransfer" class="btn btn-primary w-100">Request</a>
                </div></div>
            </div>
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm"><div class="card-body text-center p-4">
                    <h3 class="card-title h5">Incoming</h3>
                    <p class="text-muted small">Approve or reject transfers sent to you.</p>
                    <a asp-controller="Inventory" asp-action="PendingTransfers" class="btn btn-info text-white w-100">
                        Review (@Model.PendingTransfersCount)
                    </a>
                </div></div>
            </div>
        </div>
    }

    @if (Model.RecentMovements.Any())
    {
        <h4 class="mt-5 mb-3">Recent Movements</h4>
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">When</th>
                            <th>Product</th>
                            <th>Warehouse</th>
                            <th>Type</th>
                            <th class="text-end pe-3">Qty</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var move in Model.RecentMovements)
                        {
                            <tr>
                                <td class="ps-3">@move.Timestamp.ToString("MMM dd, yyyy HH:mm")</td>
                                <td><strong>@move.ProductName</strong></td>
                                <td>@move.WarehouseName</td>
                                <td><span class="badge bg-secondary">@move.MovementType</span></td>
                                <td class="text-end pe-3">@move.Quantity</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        setTimeout(function() {
            var alert = document.getElementById('success-alert');
            if (alert) { new bootstrap.Alert(alert).close(); }
        }, 5000);
    </script>
}
