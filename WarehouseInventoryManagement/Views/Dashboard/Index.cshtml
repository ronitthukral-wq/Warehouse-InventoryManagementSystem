@model Inventory.Contracts.Responses.DashboardMetricsResponse
@{
    ViewData["Title"] = Model != null && Model.IsStoreManager ? "Store Manager Dashboard" : "Admin Dashboard";
    Layout = "_Layout";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

    body, .dashboard-root {
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .dashboard-root {
        background: #f0f2f7;
        min-height: 100vh;
        padding: 2rem 1.5rem;
    }

    /* ── Hero Banner ── */
    .hero-banner {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #1a56a0 100%);
        border-radius: 24px;
        padding: 2.5rem 2.5rem;
        margin-bottom: 2rem;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: space-between;
        min-height: 180px;
    }

    .hero-banner::before {
        content: '';
        position: absolute;
        top: -60px; right: -60px;
        width: 320px; height: 320px;
        border-radius: 50%;
        background: rgba(255,255,255,0.04);
        pointer-events: none;
    }

    .hero-banner::after {
        content: '';
        position: absolute;
        bottom: -80px; left: 30%;
        width: 260px; height: 260px;
        border-radius: 50%;
        background: rgba(255,255,255,0.03);
        pointer-events: none;
    }

    .hero-text h1 {
        color: #fff;
        font-size: 2rem;
        font-weight: 800;
        margin: 0 0 .35rem;
        letter-spacing: -.5px;
    }

    .hero-text p {
        color: rgba(255,255,255,.6);
        margin: 0;
        font-size: .95rem;
    }

    .hero-badge {
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.18);
        border-radius: 50px;
        padding: .35rem 1rem;
        color: rgba(255,255,255,.85);
        font-size: .78rem;
        font-weight: 600;
        letter-spacing: .5px;
        text-transform: uppercase;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        margin-bottom: .75rem;
    }

    .hero-badge span.dot {
        width: 6px; height: 6px;
        border-radius: 50%;
        background: #4ade80;
        display: inline-block;
        box-shadow: 0 0 0 2px rgba(74,222,128,.35);
    }

    .hero-illustration {
        width: 180px;
        height: 180px;
        object-fit: contain;
        position: relative;
        z-index: 2;
        filter: drop-shadow(0 8px 24px rgba(0,0,0,.35));
        flex-shrink: 0;
    }

    .hero-actions {
        display: flex;
        gap: .75rem;
        flex-wrap: wrap;
        margin-top: 1.25rem;
    }

    .btn-hero {
        padding: .6rem 1.4rem;
        border-radius: 12px;
        font-weight: 600;
        font-size: .875rem;
        border: none;
        cursor: pointer;
        text-decoration: none;
        transition: transform .15s, box-shadow .15s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

    .btn-hero:hover { transform: translateY(-2px); text-decoration: none; }

    .btn-hero-primary {
        background: #fff;
        color: #0f172a;
        box-shadow: 0 4px 16px rgba(0,0,0,.2);
    }

    .btn-hero-secondary {
        background: rgba(255,255,255,.15);
        color: #fff;
        border: 1px solid rgba(255,255,255,.25);
    }

    /* ── Stat Grid ── */
    .stat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
        margin-bottom: 2rem;
    }

    @@media (max-width: 992px) { .stat-grid { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 576px) { .stat-grid { grid-template-columns: 1fr; } }

    .stat-card {
        background: #fff;
        border-radius: 20px;
        padding: 1.4rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: 0 2px 12px rgba(0,0,0,.06);
        transition: transform .15s, box-shadow .15s;
    }

    .stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 28px rgba(0,0,0,.1);
    }

    .stat-icon-wrap {
        width: 64px;
        height: 64px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .stat-icon-wrap svg {
        width: 36px;
        height: 36px;
    }

    .si-blue   { background: #eff6ff; }
    .si-green  { background: #f0fdf4; }
    .si-red    { background: #fff1f2; }
    .si-amber  { background: #fffbeb; }

    .stat-body { flex: 1; }

    .stat-label {
        font-size: .72rem;
        font-weight: 600;
        letter-spacing: .6px;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: .2rem;
    }

    .stat-value {
        font-size: 1.9rem;
        font-weight: 800;
        color: #0f172a;
        line-height: 1;
    }

    .stat-sub {
        font-size: .75rem;
        color: #94a3b8;
        margin-top: .2rem;
    }

    /* ── Content Grid ── */
    .content-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 1.25rem;
        margin-bottom: 2rem;
    }

    @@media (max-width: 900px) { .content-grid { grid-template-columns: 1fr; } }

    .panel {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 2px 12px rgba(0,0,0,.06);
        overflow: hidden;
    }

    .panel-header {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .panel-title {
        font-size: .95rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .panel-title svg {
        width: 20px; height: 20px;
        flex-shrink: 0;
    }

    /* ── Table ── */
    .inv-table { width: 100%; border-collapse: collapse; }

    .inv-table thead th {
        padding: .75rem 1.5rem;
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .6px;
        text-transform: uppercase;
        color: #94a3b8;
        background: #f8fafc;
        border-bottom: 1px solid #f1f5f9;
    }

    .inv-table tbody td {
        padding: .85rem 1.5rem;
        font-size: .875rem;
        color: #334155;
        border-bottom: 1px solid #f8fafc;
        vertical-align: middle;
    }

    .inv-table tbody tr:last-child td { border-bottom: none; }
    .inv-table tbody tr:hover td { background: #f8fafc; }
    .inv-table tbody tr.row-warn td { background: #fffbeb; }

    .badge-sku {
        background: #f1f5f9;
        color: #64748b;
        border-radius: 6px;
        padding: .2rem .5rem;
        font-size: .72rem;
        font-weight: 600;
        font-family: 'Courier New', monospace;
    }

    .badge-low {
        background: #fef3c7;
        color: #92400e;
        border-radius: 6px;
        padding: .15rem .5rem;
        font-size: .7rem;
        font-weight: 700;
    }

    /* ── Activity ── */
    .activity-item {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: flex-start;
        gap: .85rem;
    }

    .activity-item:last-child { border-bottom: none; }

    .activity-dot {
        width: 36px; height: 36px;
        border-radius: 10px;
        background: #eff6ff;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    .activity-dot svg { width: 18px; height: 18px; }

    .activity-body { flex: 1; }

    .activity-name {
        font-size: .875rem;
        font-weight: 600;
        color: #0f172a;
    }

    .activity-meta {
        font-size: .75rem;
        color: #94a3b8;
        margin-top: .15rem;
    }

    .activity-qty {
        font-size: .95rem;
        font-weight: 700;
        color: #0f172a;
        margin-left: auto;
        flex-shrink: 0;
    }

    .badge-type {
        border-radius: 6px;
        padding: .12rem .45rem;
        font-size: .68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .4px;
    }

    .badge-in  { background: #dcfce7; color: #166534; }
    .badge-out { background: #fee2e2; color: #991b1b; }
    .badge-tf  { background: #dbeafe; color: #1e40af; }

    /* ── Action Cards ── */
    .action-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
    }

    @@media (max-width: 768px) { .action-grid { grid-template-columns: 1fr; } }

    .action-card {
        background: #fff;
        border-radius: 20px;
        padding: 2rem 1.5rem;
        box-shadow: 0 2px 12px rgba(0,0,0,.06);
        text-align: center;
        transition: transform .15s, box-shadow .15s;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .action-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(0,0,0,.1);
    }

    .action-illus-wrap {
        width: 110px;
        height: 110px;
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.25rem;
    }

    .action-illus-wrap svg {
        width: 72px;
        height: 72px;
    }

    .action-card h3 {
        font-size: 1.05rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0 0 .5rem;
    }

    .action-card p {
        font-size: .825rem;
        color: #64748b;
        margin: 0 0 1.5rem;
        line-height: 1.55;
    }

    .btn-action {
        display: block;
        width: 100%;
        padding: .6rem 1rem;
        border-radius: 12px;
        font-size: .85rem;
        font-weight: 600;
        text-decoration: none;
        transition: all .15s;
        margin-bottom: .5rem;
        border: none;
        cursor: pointer;
    }

    .btn-action:hover { text-decoration: none; filter: brightness(1.08); transform: translateY(-1px); }

    .btn-action-dark    { background: #0f172a; color: #fff; }
    .btn-action-success { background: #16a34a; color: #fff; }
    .btn-action-info    { background: #0ea5e9; color: #fff; }
    .btn-action-outline-dark    { background: transparent; color: #0f172a; border: 1.5px solid #e2e8f0; }
    .btn-action-outline-success { background: transparent; color: #16a34a; border: 1.5px solid #bbf7d0; }
    .btn-action-outline-info    { background: transparent; color: #0ea5e9; border: 1.5px solid #bae6fd; }

    /* ── Toasts ── */
    .toast-success {
        background: #f0fdf4;
        border-left: 4px solid #22c55e;
        border-radius: 12px;
        padding: .9rem 1.2rem;
        color: #166534;
        font-weight: 600;
        font-size: .9rem;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .toast-error {
        background: #fff1f2;
        border-left: 4px solid #ef4444;
        border-radius: 12px;
        padding: .9rem 1.2rem;
        color: #991b1b;
        font-weight: 600;
        font-size: .9rem;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .toast-close {
        background: none; border: none; cursor: pointer;
        font-size: 1.1rem; color: inherit; opacity: .6;
        padding: 0; line-height: 1;
    }

    /* ── Empty State ── */
    .empty-state {
        text-align: center;
        padding: 3rem 1.5rem;
        color: #94a3b8;
    }

    .empty-state svg {
        width: 72px; height: 72px;
        margin-bottom: 1rem;
        opacity: .55;
    }

    .empty-state p { font-size: .875rem; margin: 0; }
</style>

