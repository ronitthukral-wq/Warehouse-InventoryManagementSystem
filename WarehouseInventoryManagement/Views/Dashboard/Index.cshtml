<div class="dashboard-root">

    @if (TempData["Success"] != null)
    {
        <div class="toast-success" id="toast-s">
            <span>✓ &nbsp;@TempData["Success"]</span>
            <button class="toast-close" onclick="document.getElementById('toast-s').remove()">✕</button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast-error" id="toast-e">
            <span>⚠ &nbsp;@TempData["Error"]</span>
            <button class="toast-close" onclick="document.getElementById('toast-e').remove()">✕</button>
        </div>
    }

    @if (Model != null && Model.IsStoreManager)
    {
        @* ════════════════ STORE MANAGER VIEW ════════════════ *@

        <div class="hero-banner">
            <div class="hero-text">
                <div class="hero-badge"><span class="dot"></span> Store Manager Portal</div>
                <h1>@(Model.WarehouseName ?? "My Warehouse")</h1>
                <p>Manage stock, transfers, and warehouse operations from one place.</p>
                <div class="hero-actions">
                    <a asp-controller="Inventory" asp-action="AddStock" class="btn-hero btn-hero-primary">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 1v14M1 8h14" stroke="#0f172a" stroke-width="2.2" stroke-linecap="round"/></svg>
                        Add Stock
                    </a>
                    <a asp-controller="Inventory" asp-action="RequestTransfer" class="btn-hero btn-hero-secondary">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 8h12M10 4l4 4-4 4" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Request Transfer
                    </a>
                    <a asp-controller="Inventory" asp-action="PendingTransfers" class="btn-hero btn-hero-secondary">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="8" cy="8" r="6.5" stroke="#fff" stroke-width="1.6"/><path d="M8 4.5V8l2.5 2" stroke="#fff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        View Transfers
                    </a>
                </div>
            </div>
            <svg class="hero-illustration" viewBox="0 0 200 160" xmlns="http://www.w3.org/2000/svg">
                <use href="#ic-warehouse-hero"/>
            </svg>
        </div>

        <div class="stat-grid">
            <div class="stat-card">
                <div class="stat-icon-wrap si-blue">
                    <svg><use href="#ic-box"/></svg>
                </div>
                <div class="stat-body">
                    <div class="stat-label">Products in Stock</div>
                    <div class="stat-value">@Model.TotalProducts</div>
                    <div class="stat-sub">unique SKUs</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon-wrap si-green">
                    <svg><use href="#ic-layers"/></svg>
                </div>
                <div class="stat-body">
                    <div class="stat-label">Total Units</div>
                    <div class="stat-value">@Model.TotalStockQuantity</div>
                    <div class="stat-sub">across all products</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon-wrap si-red">
                    <svg><use href="#ic-alert"/></svg>
                </div>
                <div class="stat-body">
                    <div class="stat-label">Low Stock Alerts</div>
                    <div class="stat-value" style="color:#ef4444">@Model.LowStockAlertsCount</div>
                    <div class="stat-sub">need restocking</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon-wrap si-amber">
                    <svg><use href="#ic-truck"/></svg>
                </div>
                <div class="stat-body">
                    <div class="stat-label">Pending Transfers</div>
                    <div class="stat-value" style="color:#d97706">@Model.PendingTransfersCount</div>
                    <div class="stat-sub">awaiting approval</div>
                </div>
            </div>
        </div>

        <div class="content-grid">
            <div class="panel">
                <div class="panel-header">
                    <p class="panel-title">
                        <svg><use href="#ic-grid"/></svg>
                        My Inventory
                    </p>
                </div>
                <table class="inv-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>SKU</th>
                            <th style="text-align:right">Qty</th>
                            <th style="text-align:right">Threshold</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.MyInventory.Any())
                        {
                            <tr>
                                <td colspan="4">
                                    <div class="empty-state">
                                        <svg><use href="#ic-empty-box"/></svg>
                                        <p>No products yet. Use <strong>Add Stock</strong> once the admin adds products to the catalog.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var s in Model.MyInventory)
                            {
                                <tr class="@(s.IsLowStock ? "row-warn" : "")">
                                    <td>
                                        <strong style="color:#0f172a">@s.ProductName</strong>
                                        @if (s.IsLowStock)
                                        {
                                            <span class="badge-low ms-1">Low</span>
                                        }
                                    </td>
                                    <td><span class="badge-sku">@s.SKU</span></td>
                                    <td style="text-align:right;font-weight:700;color:#0f172a">@s.Quantity</td>
                                    <td style="text-align:right;color:#94a3b8">@s.LowStockThreshold</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="panel">
                <div class="panel-header">
                    <p class="panel-title">
                        <svg><use href="#ic-activity"/></svg>
                        Recent Activity
                    </p>
                </div>
                @if (!Model.RecentMovements.Any())
                {
                    <div class="empty-state">
                        <svg><use href="#ic-no-results"/></svg>
                        <p>No activity yet.</p>
                    </div>
                }
                @foreach (var m in Model.RecentMovements)
                {
                    string typeClass = m.MovementType?.ToLower() switch
                    {
                        "in" => "badge-in",
                        "out" => "badge-out",
                        "transfer" => "badge-tf",
                        _ => "badge-tf"
                    };
                    <div class="activity-item">
                        <div class="activity-dot">
                            <svg><use href="#ic-package"/></svg>
                        </div>
                        <div class="activity-body">
                            <div class="activity-name">
                                @m.ProductName
                                <span class="badge-type @typeClass ms-1">@m.MovementType</span>
                            </div>
                            <div class="activity-meta">@m.Timestamp.ToString("MMM dd, HH:mm") &middot; @m.PerformedBy</div>
                        </div>
                        <div class="activity-qty">@m.Quantity</div>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        @* ════════════════ ADMIN VIEW ════════════════ *@

        <div class="hero-banner">
            <div class="hero-text">
                <div class="hero-badge"><span class="dot"></span> Admin Control Panel</div>
                <h1>Admin Dashboard</h1>
                <p>Full administrative access — manage warehouses, products &amp; personnel.</p>
            </div>
            <svg class="hero-illustration" viewBox="0 0 200 160" xmlns="http://www.w3.org/2000/svg">
                <use href="#ic-admin-hero"/>
            </svg>
        </div>

        <div class="stat-grid">
            <div class="stat-card">
                <div class="stat-icon-wrap si-blue">
                    <svg><use href="#ic-box"/></svg>
                </div>
                <div class="stat-body">
                    <div class="stat-label">Total Products</div>
                    <div class="stat-value">@(Model?.TotalProducts ?? 0)</div>
                    <div class="stat-sub">in catalog</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon-wrap si-green">
                    <svg><use href="#ic-layers"/></svg>
                </div>
                <div class="stat-body">
                    <div class="stat-label">Total Units</div>
                    <div class="stat-value">@(Model?.TotalStockQuantity ?? 0)</div>
                    <div class="stat-sub">across all warehouses</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon-wrap si-red">
                    <svg><use href="#ic-alert"/></svg>
                </div>
                <div class="stat-body">
                    <div class="stat-label">Low Stock Alerts</div>
                    <div class="stat-value" style="color:#ef4444">@(Model?.LowStockAlertsCount ?? 0)</div>
                    <div class="stat-sub">system-wide</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon-wrap si-amber">
                    <svg><use href="#ic-truck"/></svg>
                </div>
                <div class="stat-body">
                    <div class="stat-label">Pending Transfers</div>
                    <div class="stat-value" style="color:#d97706">@(Model?.PendingTransfersCount ?? 0)</div>
                    <div class="stat-sub">awaiting action</div>
                </div>
            </div>
        </div>

        <div class="action-grid">
            <div class="action-card">
                <div class="action-illus-wrap" style="background:#eff6ff">
                    <svg viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <!-- Warehouse building illustration -->
                        <rect x="6" y="32" width="60" height="34" rx="3" fill="#bfdbfe"/>
                        <path d="M4 34 L36 8 L68 34" fill="#93c5fd"/>
                        <rect x="6" y="32" width="60" height="34" rx="3" fill="#3b82f6" opacity=".15"/>
                        <rect x="12" y="42" width="14" height="24" rx="2" fill="#1d4ed8" opacity=".5"/>
                        <rect x="29" y="42" width="14" height="18" rx="2" fill="#1d4ed8" opacity=".5"/>
                        <rect x="46" y="42" width="14" height="24" rx="2" fill="#1d4ed8" opacity=".5"/>
                        <rect x="31" y="60" width="10" height="6" rx="1" fill="#60a5fa" opacity=".6"/>
                        <circle cx="56" cy="18" r="7" fill="#fde68a" opacity=".7"/>
                    </svg>
                </div>
                <h3>Warehouses</h3>
                <p>Monitor and manage all storage locations across every region.</p>
                <a asp-controller="Warehouse" asp-action="Index" class="btn-action btn-action-dark">View All Warehouses</a>
                <a asp-controller="Warehouse" asp-action="Create" class="btn-action btn-action-outline-dark">+ Add New Warehouse</a>
            </div>
            <div class="action-card">
                <div class="action-illus-wrap" style="background:#f0fdf4">
                    <svg viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <!-- Product/box illustration -->
                        <path d="M36 6 L62 20 L62 52 L36 66 L10 52 L10 20 Z" fill="#bbf7d0"/>
                        <path d="M36 6 L62 20 L36 34 L10 20 Z" fill="#4ade80"/>
                        <path d="M36 34 L36 66" stroke="#16a34a" stroke-width="2"/>
                        <path d="M10 20 L36 34 L62 20" stroke="#16a34a" stroke-width="2"/>
                        <path d="M23 13 L49 27" stroke="#86efac" stroke-width="1.8" stroke-linecap="round"/>
                        <path d="M36 6 L36 34" stroke="#86efac" stroke-width="1.8" stroke-linecap="round" opacity=".6"/>
                    </svg>
                </div>
                <h3>Products</h3>
                <p>Add SKUs to the global catalog. Every warehouse starts at qty 0 when a product is added.</p>
                <a asp-controller="Product" asp-action="Index" class="btn-action btn-action-success">Manage Catalog</a>
                <a asp-controller="Product" asp-action="Create" class="btn-action btn-action-outline-success">+ Add New SKU</a>
            </div>
            <div class="action-card">
                <div class="action-illus-wrap" style="background:#f0f9ff">
                    <svg viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <!-- Personnel / people illustration -->
                        <circle cx="36" cy="22" r="12" fill="#bae6fd"/>
                        <circle cx="36" cy="22" r="12" fill="#38bdf8" opacity=".4"/>
                        <path d="M14 58c0-12.15 9.85-22 22-22s22 9.85 22 22" fill="#bae6fd"/>
                        <path d="M14 58c0-12.15 9.85-22 22-22s22 9.85 22 22" fill="#0ea5e9" opacity=".25"/>
                        <circle cx="18" cy="32" r="7" fill="#e0f2fe"/>
                        <path d="M6 54c0-7.18 5.37-13 12-13" stroke="#7dd3fc" stroke-width="2" stroke-linecap="round"/>
                        <circle cx="54" cy="32" r="7" fill="#e0f2fe"/>
                        <path d="M66 54c0-7.18-5.37-13-12-13" stroke="#7dd3fc" stroke-width="2" stroke-linecap="round"/>
                        <path d="M30 22 L34 26 L43 17" stroke="#0369a1" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <h3>Personnel</h3>
                <p>Manage Store Managers. Each warehouse can only have one assigned manager.</p>
                <a asp-controller="User" asp-action="Index" class="btn-action btn-action-info">Manage Users</a>
                <a asp-controller="User" asp-action="Create" class="btn-action btn-action-outline-info">+ Register Manager</a>
            </div>
        </div>
    }
</div>