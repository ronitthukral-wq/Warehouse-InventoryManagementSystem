@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_Layout";
}

<div class="container mt-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div id="success-alert" class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-check-circle-fill fs-4 me-3"></i>
                <div>
                    <strong>Action Successful!</strong>
                    <p class="mb-0 small">@TempData["SuccessMessage"]</p>
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="p-5 mb-4 bg-light rounded-3 shadow-sm border">
        <div class="container-fluid py-2">
            <h1 class="display-5 fw-bold text-primary">Admin Control Panel</h1>
            <p class="col-md-8 fs-5 text-muted">Welcome back. You have full administrative access to manage warehouses, products, and personnel.</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="bg-dark text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                        <i class="bi bi-building fs-3"></i>
                    </div>
                    <h3 class="card-title h4">Warehouses</h3>
                    <p class="text-muted small">Monitor and manage storage locations across all regions.</p>
                    <div class="d-grid gap-2">
                        <a asp-controller="Warehouse" asp-action="Index" class="btn btn-dark">View List</a>
                        <a asp-controller="Warehouse" asp-action="Create" class="btn btn-outline-dark">Add New Warehouse</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                        <i class="bi bi-box-seam fs-3"></i>
                    </div>
                    <h3 class="card-title h4">Products</h3>
                    <p class="text-muted small">Update catalog items, SKUs, and track inventory levels.</p>
                    <div class="d-grid gap-2">
                        <a asp-controller="Product" asp-action="Index" class="btn btn-success">Manage Inventory</a>
                        <a asp-controller="Product" asp-action="Create" class="btn btn-outline-success">Add New SKU</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="bg-info text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                        <i class="bi bi-people fs-3"></i>
                    </div>
                    <h3 class="card-title h4">Personnel</h3>
                    <p class="text-muted small">Manage access control for store managers and staff.</p>
                    <div class="d-grid gap-2">
                        <a asp-controller="User" asp-action="Index" class="btn btn-info text-white">Manage Users</a>
                        <a asp-controller="User" asp-action="Create" class="btn btn-outline-info">Register Manager</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Automatically hide the alert after 5 seconds
        setTimeout(function() {
            var alert = document.getElementById('success-alert');
            if (alert) {
                var bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            }
        }, 5000);
    </script>
}