@using Inventory.Contracts.Requests.Users
@model CreateStoreManagerRequest
@{
    ViewData["Title"] = "Register Store Manager";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
    body, .form-root { font-family: 'Plus Jakarta Sans', sans-serif; }

    .form-root { background: #f0f2f7; min-height: 100vh; padding: 2rem 1.5rem; }

    .page-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #1a56a0 100%);
        border-radius: 20px; padding: 2rem 2.5rem; margin-bottom: 2rem;
        display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    }
    .page-hero-text h1 { color: #fff; font-size: 1.6rem; font-weight: 800; margin: 0 0 .3rem; }
    .page-hero-text p  { color: rgba(255,255,255,.55); font-size: .875rem; margin: 0; }

    .page-hero-icon {
        width: 72px; height: 72px; background: rgba(255,255,255,.1);
        border: 1.5px solid rgba(255,255,255,.15); border-radius: 20px;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .page-hero-icon svg { width: 36px; height: 36px; }

    .form-card { background: #fff; border-radius: 20px; box-shadow: 0 2px 12px rgba(0,0,0,.07); max-width: 640px; margin: 0 auto; overflow: hidden; }
    .form-card-header { padding: 1.5rem 2rem; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; gap: .75rem; }
    .form-card-header svg { width: 22px; height: 22px; flex-shrink: 0; }
    .form-card-header h2 { font-size: 1rem; font-weight: 700; color: #0f172a; margin: 0; }
    .form-card-body { padding: 2rem; }

    .form-info-box {
        background: #eff6ff; border-left: 3px solid #3b82f6; border-radius: 10px;
        padding: .85rem 1rem; font-size: .82rem; color: #1e40af;
        margin-bottom: 1.75rem; display: flex; align-items: flex-start; gap: .5rem;
    }
    .form-info-box svg { width: 16px; height: 16px; flex-shrink: 0; margin-top: 1px; }

    .field-wrap { margin-bottom: 1.25rem; }
    .field-label { font-size: .75rem; font-weight: 700; letter-spacing: .5px; text-transform: uppercase; color: #64748b; margin-bottom: .45rem; display: block; }

    .field-input, .field-select {
        width: 100%; padding: .72rem 1rem; border: 1.5px solid #e2e8f0; border-radius: 12px;
        font-size: .9rem; font-family: inherit; color: #0f172a; background: #f8fafc;
        transition: border-color .15s, box-shadow .15s; outline: none; box-sizing: border-box; appearance: none;
    }
    .field-input:focus, .field-select:focus {
        border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,.12); background: #fff;
    }
    .field-input[readonly] { background: #f1f5f9; color: #94a3b8; cursor: not-allowed; }
    .field-hint { font-size: .75rem; color: #94a3b8; margin-top: .35rem; display: block; }
    .field-error { color: #ef4444; font-size: .76rem; margin-top: .3rem; display: block; }

    .validation-summary-errors {
        background: #fff1f2; border-left: 3px solid #ef4444; border-radius: 10px;
        padding: .75rem 1rem; color: #991b1b; font-size: .82rem; margin-bottom: 1.25rem;
    }

    .role-badge {
        display: inline-flex; align-items: center; gap: .4rem;
        background: #f0f9ff; border: 1.5px solid #bae6fd; border-radius: 10px;
        padding: .6rem 1rem; font-size: .85rem; font-weight: 600; color: #0369a1; width: 100%;
    }
    .role-badge svg { width: 16px; height: 16px; }

    .form-actions { display: flex; justify-content: flex-end; gap: .6rem; margin-top: 2rem; }

    .btn-submit {
        padding: .75rem 1.75rem; background: linear-gradient(135deg, #1e3a5f, #1a56a0); color: #fff; border: none;
        border-radius: 14px; font-size: .9rem; font-weight: 700; font-family: inherit;
        cursor: pointer; transition: all .15s; display: inline-flex; align-items: center; gap: .5rem;
    }
    .btn-submit:hover { filter: brightness(1.1); transform: translateY(-1px); }

    .btn-cancel {
        padding: .75rem 1.5rem; background: transparent; color: #64748b; border: 1.5px solid #e2e8f0;
        border-radius: 14px; font-size: .875rem; font-weight: 600; font-family: inherit;
        cursor: pointer; text-decoration: none; transition: all .15s; display: inline-flex; align-items: center;
    }
    .btn-cancel:hover { background: #f8fafc; color: #0f172a; text-decoration: none; }
</style>

<div class="form-root">
    <div class="page-hero">
        <div class="page-hero-text">
            <h1>Register Store Manager</h1>
            <p>Create a new manager account and assign them to a warehouse</p>
        </div>
        <div class="page-hero-icon">
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="18" cy="12" r="6" stroke="#fff" stroke-width="1.8"/>
                <path d="M6 30c0-6.627 5.373-12 12-12s12 5.373 12 12" stroke="#fff" stroke-width="1.8" stroke-linecap="round"/>
                <line x1="28" y1="6" x2="28" y2="12" stroke="rgba(255,255,255,.6)" stroke-width="1.8" stroke-linecap="round"/>
                <line x1="25" y1="9" x2="31" y2="9" stroke="rgba(255,255,255,.6)" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
        </div>
    </div>

    <div class="form-card">
        <div class="form-card-header">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke="#0ea5e9" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="12" cy="7" r="4" stroke="#0ea5e9" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <h2>New Store Manager Account</h2>
        </div>

        <div class="form-card-body">
            <div class="form-info-box">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="12" cy="12" r="10" stroke="#3b82f6" stroke-width="1.8"/>
                    <line x1="12" y1="8" x2="12" y2="12" stroke="#3b82f6" stroke-width="1.8" stroke-linecap="round"/>
                    <line x1="12" y1="16" x2="12.01" y2="16" stroke="#3b82f6" stroke-width="2.2" stroke-linecap="round"/>
                </svg>
                <span>Create a Store Manager and assign them to an existing warehouse. The new user can sign in immediately with the credentials below.</span>
            </div>

            <form asp-action="Create" method="post" autocomplete="off">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                <div class="field-wrap">
                    <label asp-for="Email" class="field-label">Email Address</label>
                    <input asp-for="Email" class="field-input" placeholder="manager@company.com" />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                <div class="field-wrap">
                    <label asp-for="Password" class="field-label">Password</label>
                    <input asp-for="Password" type="password" class="field-input" placeholder="Minimum 6 characters" />
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>

                <div class="field-wrap">
                    <label asp-for="WarehouseId" class="field-label">Assigned Warehouse</label>
                    <select asp-for="WarehouseId" asp-items="ViewBag.Warehouses as SelectList" class="field-select">
                        <option value="">— Select a warehouse —</option>
                    </select>
                    <span asp-validation-for="WarehouseId" class="field-error"></span>
                    <span class="field-hint">Only existing warehouses appear here. Create a warehouse first if the list is empty.</span>
                </div>

                <div class="field-wrap">
                    <label class="field-label">Role</label>
                    <div class="role-badge">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="#0369a1" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        StoreManager — fixed for this form
                    </div>
                </div>

                <div class="form-actions">
                    <a asp-action="Index" class="btn-cancel">Cancel</a>
                    <button type="submit" class="btn-submit">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="none"><path d="M2 8l4 4 8-8" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Create Account
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}