@model IEnumerable<Inventory.Contracts.Responses.UserResponse>
@{
    ViewData["Title"] = "User Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>System Users</h2>
    <a asp-action="Create" class="btn btn-primary">Create New Manager</a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Email / Username</th>
                    <th>Role</th>
                    <th>Assigned Warehouse</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        @* Use Email since FirstName/LastName are not in UserResponse *@
                        <td><strong>@user.Email</strong></td>
                        <td>
                            <span class="badge @(user.Role == "Admin" ? "bg-danger" : "bg-info")">
                                @user.Role
                            </span>
                        </td>
                        <td>@(user.AssignedWarehouseName ?? "No Warehouse Assigned")</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>