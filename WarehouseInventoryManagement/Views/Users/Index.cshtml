@model IEnumerable<Inventory.Contracts.Responses.UserResponse>
@{
    ViewData["Title"] = "Personnel";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Personnel</h2>
            <p class="text-muted small mb-0">Manage administrators and store managers across your warehouses.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-person-plus-fill me-1"></i>Register Manager
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Email / Username</th>
                        <th>Role</th>
                        <th>Assigned Warehouse</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                No users found. Click <strong>Register Manager</strong> to add one.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td class="ps-3"><strong>@user.Email</strong></td>
                                <td>
                                    <span class="badge @(user.Role == "Admin" ? "bg-danger" : "bg-info text-dark")">
                                        @(string.IsNullOrEmpty(user.Role) ? "—" : user.Role)
                                    </span>
                                </td>
                                <td>
                                    @if (string.IsNullOrEmpty(user.AssignedWarehouseName))
                                    {
                                        <span class="text-muted fst-italic">No warehouse assigned</span>
                                    }
                                    else
                                    {
                                        @user.AssignedWarehouseName
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    @if (user.Role == "StoreManager")
                                    {
                                        <a asp-action="Edit" asp-route-id="@user.Id"
                                               class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil me-1"></i>Edit
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Read-only</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
