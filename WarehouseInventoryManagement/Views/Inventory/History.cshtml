@model IEnumerable<Inventory.Contracts.Responses.MovementHistoryResponse>
@{
    ViewData["Title"] = "Stock Movement History";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

    body, .page-root { font-family: 'Plus Jakarta Sans', sans-serif; }

    .page-root {
        background: #f0f2f7;
        min-height: 100vh;
        padding: 2rem 1.5rem;
    }

    .page-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #1a56a0 100%);
        border-radius: 20px;
        padding: 2rem 2.5rem;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .page-hero-text h1 {
        color: #fff;
        font-size: 1.6rem;
        font-weight: 800;
        margin: 0 0 .3rem;
    }

    .page-hero-text p { color: rgba(255,255,255,.55); font-size: .875rem; margin: 0; }

    .hero-actions { display: flex; gap: .6rem; flex-wrap: wrap; }

    .btn-hero {
        padding: .55rem 1.2rem;
        border-radius: 12px;
        font-weight: 600;
        font-size: .85rem;
        border: none;
        cursor: pointer;
        text-decoration: none;
        transition: transform .15s;
        display: inline-flex; align-items: center; gap: .4rem;
    }

    .btn-hero:hover { transform: translateY(-2px); text-decoration: none; }
    .btn-hero-white { background: #fff; color: #0f172a; }
    .btn-hero-ghost { background: rgba(255,255,255,.15); color: #fff; border: 1px solid rgba(255,255,255,.25); }

    .panel {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 2px 12px rgba(0,0,0,.06);
        overflow: hidden;
    }

    .panel-header {
        padding: 1.25rem 1.75rem;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .panel-title {
        font-size: .95rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .panel-title svg { width: 20px; height: 20px; }

    .panel-count {
        background: #f1f5f9;
        color: #64748b;
        border-radius: 20px;
        padding: .2rem .7rem;
        font-size: .75rem;
        font-weight: 700;
    }

    .hist-table { width: 100%; border-collapse: collapse; }

    .hist-table thead th {
        padding: .75rem 1.75rem;
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: .6px;
        text-transform: uppercase;
        color: #94a3b8;
        background: #f8fafc;
        border-bottom: 1px solid #f1f5f9;
        white-space: nowrap;
    }

    .hist-table tbody td {
        padding: .9rem 1.75rem;
        font-size: .875rem;
        color: #334155;
        border-bottom: 1px solid #f8fafc;
        vertical-align: middle;
    }

    .hist-table tbody tr:last-child td { border-bottom: none; }
    .hist-table tbody tr:hover td { background: #f8fafc; }

    .badge-type {
        border-radius: 7px;
        padding: .22rem .6rem;
        font-size: .7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .4px;
        white-space: nowrap;
    }

    .bt-transfer { background: #dbeafe; color: #1e40af; }
    .bt-purchase { background: #dcfce7; color: #166534; }
    .bt-other    { background: #f1f5f9; color: #475569; }

    .badge-user {
        font-size: .75rem;
        color: #94a3b8;
        font-weight: 500;
    }

    .ts-text {
        font-size: .8rem;
        color: #64748b;
        white-space: nowrap;
    }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: #94a3b8;
    }

    .empty-state svg { width: 64px; height: 64px; margin-bottom: 1rem; opacity: .5; }
    .empty-state p { font-size: .9rem; margin: 0; }
</style>

<div class="page-root">
    <div class="page-hero">
        <div class="page-hero-text">
            <h1>Movement History</h1>
            <p>Full log of all stock changes across your warehouse</p>
        </div>
        <div class="hero-actions">
            <a asp-action="AddStock" class="btn-hero btn-hero-white">
                <svg viewBox="0 0 16 16" width="13" height="13" fill="none"><path d="M8 1v14M1 8h14" stroke="#0f172a" stroke-width="2.2" stroke-linecap="round"/></svg>
                Add Stock
            </a>
            <a asp-action="RequestTransfer" class="btn-hero btn-hero-ghost">
                <svg viewBox="0 0 16 16" width="13" height="13" fill="none"><path d="M2 8h12M10 4l4 4-4 4" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Request Transfer
            </a>
        </div>
    </div>

    <div class="panel">
        <div class="panel-header">
            <p class="panel-title">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" stroke="#6366f1" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Stock Movements
            </p>
            <span class="panel-count">@Model.Count() records</span>
        </div>

        <table class="hist-table" id="history-table">
            <thead>
                <tr>
                    <th>Timestamp</th>
                    <th>Product</th>
                    <th>Warehouse</th>
                    <th style="text-align:right">Qty</th>
                    <th>Type</th>
                    <th>Performed By</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6">
                            <div class="empty-state">
                                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <circle cx="11" cy="11" r="8" stroke="#cbd5e1" stroke-width="1.6"/>
                                    <line x1="21" y1="21" x2="16.65" y2="16.65" stroke="#cbd5e1" stroke-width="1.6" stroke-linecap="round"/>
                                    <line x1="8" y1="11" x2="14" y2="11" stroke="#cbd5e1" stroke-width="1.6" stroke-linecap="round"/>
                                </svg>
                                <p>No movement history recorded yet.</p>
                            </div>
                        </td>
                    </tr>
                }
                @foreach (var move in Model)
                {
                    string badgeClass = move.MovementType.Contains("Transfer") ? "bt-transfer"
                                      : move.MovementType.Contains("Purchase") ? "bt-purchase"
                                      : "bt-other";
                    <tr>
                        <td><span class="ts-text">@move.Timestamp.ToString("MMM dd, yyyy HH:mm")</span></td>
                        <td><strong style="color:#0f172a">@move.ProductName</strong></td>
                        <td style="color:#64748b">@move.WarehouseName</td>
                        <td style="text-align:right;font-weight:700;color:#0f172a">@move.Quantity</td>
                        <td><span class="badge-type @badgeClass">@move.MovementType</span></td>
                        <td><span class="badge-user">@move.PerformedBy</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

                        @section Scripts {
<script>
    $(document).ready(function () {
        $('#history-table').DataTable({
            pageLength: 15,
            lengthMenu: [15, 25, 50, 100],
            order: [[0, 'desc']],         // newest movements first
            columnDefs: [
                { orderable: false, targets: [4, 5] }  // Type, Performed By not sortable
            ]
        });
    });
</script>
}