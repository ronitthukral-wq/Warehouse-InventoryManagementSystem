@model Inventory.Contracts.Requests.Inventory.CreateTransferRequest
@{
    ViewData["Title"] = "Request Stock Transfer";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
    body, .form-root { font-family: 'Plus Jakarta Sans', sans-serif; }

    .form-root { background: #f0f2f7; min-height: 100vh; padding: 2rem 1.5rem; }

    .page-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #1a56a0 100%);
        border-radius: 20px; padding: 2rem 2.5rem; margin-bottom: 2rem;
        display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    }
    .page-hero-text h1 { color: #fff; font-size: 1.6rem; font-weight: 800; margin: 0 0 .3rem; }
    .page-hero-text p  { color: rgba(255,255,255,.55); font-size: .875rem; margin: 0; }

    .page-hero-icon {
        width: 72px; height: 72px;
        background: rgba(255,255,255,.1); border: 1.5px solid rgba(255,255,255,.15);
        border-radius: 20px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .page-hero-icon svg { width: 36px; height: 36px; }

    .form-card { background: #fff; border-radius: 20px; box-shadow: 0 2px 12px rgba(0,0,0,.07); max-width: 600px; margin: 0 auto; overflow: hidden; }

    .form-card-header { padding: 1.5rem 2rem; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; gap: .75rem; }
    .form-card-header svg { width: 22px; height: 22px; flex-shrink: 0; }
    .form-card-header h2 { font-size: 1rem; font-weight: 700; color: #0f172a; margin: 0; }
    .form-card-body { padding: 2rem; }

    .form-info-box {
        background: #eff6ff; border-left: 3px solid #3b82f6; border-radius: 10px;
        padding: .85rem 1rem; font-size: .82rem; color: #1e40af;
        margin-bottom: 1.75rem; display: flex; align-items: flex-start; gap: .5rem;
    }
    .form-info-box svg { width: 16px; height: 16px; flex-shrink: 0; margin-top: 1px; }

    .field-wrap { margin-bottom: 1.25rem; }
    .field-label { font-size: .75rem; font-weight: 700; letter-spacing: .5px; text-transform: uppercase; color: #64748b; margin-bottom: .45rem; display: block; }

    .field-input, .field-select {
        width: 100%; padding: .72rem 1rem; border: 1.5px solid #e2e8f0; border-radius: 12px;
        font-size: .9rem; font-family: inherit; color: #0f172a; background: #f8fafc;
        transition: border-color .15s, box-shadow .15s; outline: none; box-sizing: border-box; appearance: none;
    }
    .field-input:focus, .field-select:focus {
        border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,.12); background: #fff;
    }
    .field-error { color: #ef4444; font-size: .76rem; margin-top: .3rem; display: block; }

    .validation-summary-errors {
        background: #fff1f2; border-left: 3px solid #ef4444; border-radius: 10px;
        padding: .75rem 1rem; color: #991b1b; font-size: .82rem; margin-bottom: 1.25rem;
    }

    .form-actions { display: grid; gap: .6rem; margin-top: 2rem; }

    .btn-submit {
        padding: .8rem 1rem; background: linear-gradient(135deg, #1e3a5f, #1a56a0); color: #fff;
        border: none; border-radius: 14px; font-size: .9rem; font-weight: 700; font-family: inherit;
        cursor: pointer; transition: transform .15s, filter .15s;
        display: flex; align-items: center; justify-content: center; gap: .5rem;
    }
    .btn-submit:hover { filter: brightness(1.1); transform: translateY(-1px); }

    .btn-cancel {
        padding: .75rem 1rem; background: transparent; color: #64748b; border: 1.5px solid #e2e8f0;
        border-radius: 14px; font-size: .875rem; font-weight: 600; font-family: inherit;
        cursor: pointer; text-align: center; text-decoration: none; transition: all .15s; display: block;
    }
    .btn-cancel:hover { background: #f8fafc; color: #0f172a; text-decoration: none; }
</style>

<div class="form-root">
    <div class="page-hero">
        <div class="page-hero-text">
            <h1>Request Stock Transfer</h1>
            <p>Pull stock from another warehouse into yours</p>
        </div>
        <div class="page-hero-icon">
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4 18h28M22 10l10 8-10 8" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M14 10L4 18l10 8" stroke="rgba(255,255,255,.5)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </div>
    </div>

    <div class="form-card">
        <div class="form-card-header">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2 8h12M10 4l4 4-4 4" stroke="#3b82f6" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M22 16H10M14 20l-4-4 4-4" stroke="#3b82f6" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <h2>Transfer Request Form</h2>
        </div>

        <div class="form-card-body">
            <div class="form-info-box">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="12" cy="12" r="10" stroke="#3b82f6" stroke-width="1.8"/>
                    <line x1="12" y1="8" x2="12" y2="12" stroke="#3b82f6" stroke-width="1.8" stroke-linecap="round"/>
                    <line x1="12" y1="16" x2="12.01" y2="16" stroke="#3b82f6" stroke-width="2.2" stroke-linecap="round"/>
                </svg>
                <span>Request stock from another warehouse to be sent to <strong>your</strong> warehouse. The source warehouse manager will accept or reject the request.</span>
            </div>

            <form asp-action="RequestTransfer" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                <div class="field-wrap">
                    <label asp-for="ProductId" class="field-label">Product</label>
                    <select asp-for="ProductId" asp-items="ViewBag.Products as Microsoft.AspNetCore.Mvc.Rendering.SelectList" class="field-select">
                        <option value="">— Select a product —</option>
                    </select>
                    <span asp-validation-for="ProductId" class="field-error"></span>
                </div>

                <div class="field-wrap">
                    <label asp-for="FromWarehouseId" class="field-label">Source Warehouse (pull stock from)</label>
                    <select asp-for="FromWarehouseId" asp-items="ViewBag.Warehouses as Microsoft.AspNetCore.Mvc.Rendering.SelectList" class="field-select">
                        <option value="">— Select source warehouse —</option>
                    </select>
                    <span asp-validation-for="FromWarehouseId" class="field-error"></span>
                </div>

                <div class="field-wrap">
                    <label asp-for="Quantity" class="field-label">Quantity</label>
                    <input asp-for="Quantity" type="number" min="1" class="field-input" placeholder="0" />
                    <span asp-validation-for="Quantity" class="field-error"></span>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-submit">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="none"><path d="M2 8h12M10 4l4 4-4 4" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Send Request
                    </button>
                    <a asp-action="PendingTransfers" class="btn-cancel">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}