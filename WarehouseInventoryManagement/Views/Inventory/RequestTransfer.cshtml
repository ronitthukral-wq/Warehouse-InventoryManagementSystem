@model CreateTransferRequest
@{
    ViewData["Title"] = "Request Stock Transfer";
}

<h4>Initiate Transfer</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="RequestTransfer">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="ProductId" class="control-label">Product ID</label>
                <input asp-for="ProductId" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="ToWarehouseId" class="control-label">Destination Warehouse ID</label>
                <input asp-for="ToWarehouseId" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="Quantity" class="control-label"></label>
                <input asp-for="Quantity" class="form-control" />
            </div>
            <div class="form-group mt-3">
                <input type="submit" value="Send Request" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>