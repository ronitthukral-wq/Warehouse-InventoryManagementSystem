@model AddStockRequest
@{
    ViewData["Title"] = "Add Stock";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Add Stock to Warehouse</h4>
            </div>
            <div class="card-body">
                <form asp-action="AddStock" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-group mb-3">
                        <label asp-for="ProductId" class="form-label font-weight-bold">Product ID</label>
                        <input asp-for="ProductId" class="form-control" placeholder="Enter Product ID" />
                        <span asp-validation-for="ProductId" class="text-danger"></span>
                        <small class="form-text text-muted">Enter the unique ID of the product being added.</small>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Quantity" class="form-label font-weight-bold">Quantity</label>
                        <input asp-for="Quantity" type="number" class="form-control" placeholder="0" />
                        <span asp-validation-for="Quantity" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success">Confirm Addition</button>
                        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}