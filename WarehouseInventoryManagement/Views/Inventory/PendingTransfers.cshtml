@foreach (var item in Model)
{
    <tr>
        @* Update 'ProductName' to the property actually in your Response class *@
        <td>@item.ProductName</td>
        <td>@item.Quantity</td>
        @* Ensure 'ToWarehouseName' matches your backend property exactly *@
        <td>@item.ToWarehouseName</td>
        @* Use 'Timestamp' if 'CreatedDate' is missing *@
        <td>@item.Timestamp.ToShortDateString()</td>
        @* ... rest of row *@
    </tr>
}