@model IEnumerable<Inventory.Contracts.Responses.TransferRequestResponse>
@{
    ViewData["Title"] = "Transfers";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
    body, .page-root { font-family: 'Plus Jakarta Sans', sans-serif; }

    .page-root { background: #f0f2f7; min-height: 100vh; padding: 2rem 1.5rem; }

    .page-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #1a56a0 100%);
        border-radius: 20px; padding: 2rem 2.5rem; margin-bottom: 2rem;
        display: flex; align-items: center; justify-content: space-between;
        flex-wrap: wrap; gap: 1rem;
    }
    .page-hero-text h1 { color: #fff; font-size: 1.6rem; font-weight: 800; margin: 0 0 .3rem; }
    .page-hero-text p  { color: rgba(255,255,255,.55); font-size: .875rem; margin: 0; }

    .hero-actions { display: flex; gap: .6rem; flex-wrap: wrap; }

    .btn-hero {
        padding: .55rem 1.2rem; border-radius: 12px; font-weight: 600;
        font-size: .85rem; border: none; cursor: pointer; text-decoration: none;
        transition: transform .15s; display: inline-flex; align-items: center; gap: .4rem;
    }
    .btn-hero:hover { transform: translateY(-2px); text-decoration: none; }
    .btn-hero-white { background: #fff; color: #0f172a; box-shadow: 0 4px 14px rgba(0,0,0,.15); }
    .btn-hero-ghost { background: rgba(255,255,255,.15); color: #fff; border: 1px solid rgba(255,255,255,.25); }

    .toast-error {
        background: #fff1f2; border-left: 4px solid #ef4444; border-radius: 12px;
        padding: .9rem 1.2rem; color: #991b1b; font-weight: 600; font-size: .9rem;
        margin-bottom: 1.25rem; display: flex; align-items: center; justify-content: space-between;
    }
    .toast-close { background: none; border: none; cursor: pointer; font-size: 1.1rem; color: inherit; opacity: .6; padding: 0; }

    .panel { background: #fff; border-radius: 20px; box-shadow: 0 2px 12px rgba(0,0,0,.06); overflow: hidden; }

    .panel-header {
        padding: 1.25rem 1.75rem; border-bottom: 1px solid #f1f5f9;
        display: flex; align-items: center; justify-content: space-between;
    }
    .panel-title { font-size: .95rem; font-weight: 700; color: #0f172a; margin: 0; display: flex; align-items: center; gap: .5rem; }
    .panel-title svg { width: 20px; height: 20px; }
    .panel-count { background: #f1f5f9; color: #64748b; border-radius: 20px; padding: .2rem .7rem; font-size: .75rem; font-weight: 700; }

    .tr-table { width: 100%; border-collapse: collapse; }
    .tr-table thead th {
        padding: .75rem 1.5rem; font-size: .7rem; font-weight: 700; letter-spacing: .6px;
        text-transform: uppercase; color: #94a3b8; background: #f8fafc; border-bottom: 1px solid #f1f5f9; white-space: nowrap;
    }
    .tr-table tbody td {
        padding: .9rem 1.5rem; font-size: .875rem; color: #334155;
        border-bottom: 1px solid #f8fafc; vertical-align: middle;
    }
    .tr-table tbody tr:last-child td { border-bottom: none; }
    .tr-table tbody tr:hover td { background: #f8fafc; }

    .ts-text { font-size: .78rem; color: #94a3b8; white-space: nowrap; }

    .dir-badge, .status-badge {
        border-radius: 7px; padding: .22rem .6rem; font-size: .68rem;
        font-weight: 700; text-transform: uppercase; letter-spacing: .4px; white-space: nowrap;
    }
    .dir-in      { background: #dbeafe; color: #1e40af; }
    .dir-out     { background: #ede9fe; color: #5b21b6; }
    .st-pending  { background: #fef3c7; color: #92400e; }
    .st-accepted { background: #dcfce7; color: #166534; }
    .st-rejected { background: #f1f5f9; color: #475569; }
    .st-other    { background: #f1f5f9; color: #64748b; }

    .action-btn {
        padding: .3rem .8rem; border-radius: 8px; font-size: .75rem; font-weight: 700;
        border: none; cursor: pointer; text-decoration: none; transition: all .12s;
        display: inline-flex; align-items: center; gap: .3rem;
    }
    .action-btn:hover { transform: translateY(-1px); filter: brightness(1.07); }
    .btn-accept  { background: #dcfce7; color: #166534; }
    .btn-reject  { background: #fee2e2; color: #991b1b; }

    .empty-state { text-align: center; padding: 4rem 2rem; color: #94a3b8; }
    .empty-state svg { width: 64px; height: 64px; margin-bottom: 1rem; opacity: .45; }
    .empty-state p { font-size: .9rem; margin: 0; }
</style>

<div class="page-root">
    <div class="page-hero">
        <div class="page-hero-text">
            <h1>Stock Transfers</h1>
            <p>Manage incoming and outgoing transfer requests for your warehouse</p>
        </div>
        <div class="hero-actions">
            <a asp-action="AddStock" class="btn-hero btn-hero-white">
                <svg viewBox="0 0 16 16" width="13" height="13" fill="none"><path d="M8 1v14M1 8h14" stroke="#0f172a" stroke-width="2.2" stroke-linecap="round"/></svg>
                Add Stock
            </a>
            <a asp-action="RequestTransfer" class="btn-hero btn-hero-ghost">
                <svg viewBox="0 0 16 16" width="13" height="13" fill="none"><path d="M2 8h12M10 4l4 4-4 4" stroke="#fff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Request Transfer
            </a>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="toast-error" id="toast-e">
            <span>⚠ &nbsp;@TempData["Error"]</span>
            <button class="toast-close" onclick="document.getElementById('toast-e').remove()">✕</button>
        </div>
    }

    <div class="panel">
        <div class="panel-header">
            <p class="panel-title">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M2 8h12M10 4l4 4-4 4" stroke="#6366f1" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M22 16H10M14 20l-4-4 4-4" stroke="#6366f1" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Transfer Requests
            </p>
            @if (Model != null)
            {
                <span class="panel-count">@Model.Count() records</span>
            }
        </div>

        <table class="tr-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Direction</th>
                    <th>Product</th>
                    <th>From</th>
                    <th>To</th>
                    <th style="text-align:right">Qty</th>
                    <th>Status</th>
                    <th style="text-align:right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr><td colspan="8">
                        <div class="empty-state">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M2 8h12M10 4l4 4-4 4" stroke="#cbd5e1" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M22 16H10M14 20l-4-4 4-4" stroke="#cbd5e1" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            <p>No transfers involving your warehouse yet.</p>
                        </div>
                    </td></tr>
                }
                else
                {
                    foreach (var t in Model)
                    {
                        string stClass = t.Status switch {
                            "Pending"  => "st-pending",
                            "Accepted" => "st-accepted",
                            "Rejected" => "st-rejected",
                            _          => "st-other"
                        };
                        string dirClass = t.Direction == "Incoming" ? "dir-in" : "dir-out";

                        <tr>
                            <td><span class="ts-text">@t.CreatedDate.ToString("MMM dd, yyyy HH:mm")</span></td>
                            <td><span class="dir-badge @dirClass">@t.Direction</span></td>
                            <td><strong style="color:#0f172a">@t.Product</strong></td>
                            <td style="color:#64748b;font-size:.82rem">@t.FromWarehouseName</td>
                            <td style="color:#64748b;font-size:.82rem">@t.ToWarehouseName</td>
                            <td style="text-align:right;font-weight:700;color:#0f172a">@t.Quantity</td>
                            <td><span class="status-badge @stClass">@t.Status</span></td>
                            <td style="text-align:right">
                                @if (t.IsActionable)
                                {
                                    <form asp-action="RespondToTransfer" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="TransferRequestId" value="@t.Id" />
                                        <input type="hidden" name="Accept" value="true" />
                                        <button type="submit" class="action-btn btn-accept">✓ Accept</button>
                                    </form>
                                    <form asp-action="RespondToTransfer" method="post" style="display:inline;margin-left:.35rem">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="TransferRequestId" value="@t.Id" />
                                        <input type="hidden" name="Accept" value="false" />
                                        <button type="submit" class="action-btn btn-reject">✕ Reject</button>
                                    </form>
                                }
                                else
                                {
                                    <span style="color:#cbd5e1;font-size:.85rem">&mdash;</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>