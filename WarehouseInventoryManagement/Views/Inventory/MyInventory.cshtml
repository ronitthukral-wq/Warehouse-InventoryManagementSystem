@using Inventory.Contracts.Responses
@model List<StockLevelResponse>
@{
    ViewData["Title"] = "My Warehouse Inventory";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

    body, .page-root { font-family: 'Plus Jakarta Sans', sans-serif; }

    .page-root {
        background: #f0f2f7;
        min-height: 100vh;
        padding: 2rem 1.5rem;
    }

    .page-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #1a56a0 100%);
        border-radius: 20px;
        padding: 2rem 2.5rem;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .page-hero-text h1 { color: #fff; font-size: 1.6rem; font-weight: 800; margin: 0 0 .3rem; }
    .page-hero-text p  { color: rgba(255,255,255,.55); font-size: .875rem; margin: 0; }

    .btn-hero {
        padding: .6rem 1.4rem;
        border-radius: 12px;
        font-weight: 600;
        font-size: .875rem;
        border: none;
        cursor: pointer;
        text-decoration: none;
        transition: transform .15s;
        display: inline-flex; align-items: center; gap: .4rem;
        background: #fff;
        color: #0f172a;
        box-shadow: 0 4px 14px rgba(0,0,0,.15);
    }

    .btn-hero:hover { transform: translateY(-2px); text-decoration: none; }

    .toast-success {
        background: #f0fdf4;
        border-left: 4px solid #22c55e;
        border-radius: 12px;
        padding: .9rem 1.2rem;
        color: #166534;
        font-weight: 600;
        font-size: .9rem;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .toast-close {
        background: none; border: none; cursor: pointer;
        font-size: 1.1rem; color: inherit; opacity: .6; padding: 0;
    }

    .summary-strip {
        display: flex;
        gap: .75rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }

    .summary-chip {
        background: #fff;
        border-radius: 12px;
        padding: .6rem 1.1rem;
        font-size: .8rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: .4rem;
        box-shadow: 0 1px 6px rgba(0,0,0,.05);
    }

    .chip-dot {
        width: 8px; height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .chip-healthy .chip-dot { background: #22c55e; }
    .chip-low     .chip-dot { background: #f59e0b; }
    .chip-out     .chip-dot { background: #ef4444; }
    .chip-total   .chip-dot { background: #3b82f6; }

    .chip-healthy { color: #166534; }
    .chip-low     { color: #92400e; }
    .chip-out     { color: #991b1b; }
    .chip-total   { color: #1e40af; }

    .panel {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 2px 12px rgba(0,0,0,.06);
        overflow: hidden;
    }

    .panel-header {
        padding: 1.25rem 1.75rem;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .panel-title {
        font-size: .95rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .panel-title svg { width: 20px; height: 20px; }

    .inv-table { width: 100%; border-collapse: collapse; }

    .inv-table thead th {
        padding: .75rem 1.75rem;
        font-size: .7rem;
        font-weight: 700;
        letter-spacing: .6px;
        text-transform: uppercase;
        color: #94a3b8;
        background: #f8fafc;
        border-bottom: 1px solid #f1f5f9;
    }

    .inv-table tbody td {
        padding: .9rem 1.75rem;
        font-size: .875rem;
        color: #334155;
        border-bottom: 1px solid #f8fafc;
        vertical-align: middle;
    }

    .inv-table tbody tr:last-child td { border-bottom: none; }
    .inv-table tbody tr:hover td { background: #f8fafc; }
    .inv-table tbody tr.row-out  td { background: #fff1f2; }
    .inv-table tbody tr.row-warn td { background: #fffbeb; }

    .prod-link {
        font-weight: 700;
        color: #0f172a;
        text-decoration: none;
        transition: color .12s;
    }

    .prod-link:hover { color: #2563eb; text-decoration: none; }

    .badge-sku {
        background: #f1f5f9;
        color: #64748b;
        border-radius: 6px;
        padding: .18rem .5rem;
        font-size: .72rem;
        font-weight: 600;
        font-family: 'Courier New', monospace;
    }

    .status-badge {
        border-radius: 8px;
        padding: .25rem .65rem;
        font-size: .72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .4px;
        white-space: nowrap;
    }

    .sb-ok  { background: #dcfce7; color: #166534; }
    .sb-low { background: #fef3c7; color: #92400e; }
    .sb-out { background: #fee2e2; color: #991b1b; }

    .empty-panel {
        text-align: center;
        padding: 4rem 2rem;
    }

    .empty-panel svg { width: 72px; height: 72px; margin-bottom: 1rem; opacity: .45; }
    .empty-panel p   { font-size: .9rem; color: #94a3b8; margin: 0 0 1.25rem; }

    .btn-add-first {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .65rem 1.5rem;
        background: #16a34a;
        color: #fff;
        border-radius: 12px;
        font-size: .875rem;
        font-weight: 700;
        text-decoration: none;
        transition: all .15s;
    }

    .btn-add-first:hover { filter: brightness(1.08); transform: translateY(-1px); text-decoration: none; color: #fff; }
</style>

<div class="page-root">
    <div class="page-hero">
        <div class="page-hero-text">
            <h1>My Warehouse Inventory</h1>
            <p>All products stocked in your warehouse — click a product to view details</p>
        </div>
        <a asp-controller="Inventory" asp-action="AddStock" class="btn-hero">
            <svg viewBox="0 0 16 16" width="13" height="13" fill="none"><path d="M8 1v14M1 8h14" stroke="#0f172a" stroke-width="2.2" stroke-linecap="round"/></svg>
            Add Stock
        </a>
    </div>

    @await Component.InvokeAsync("AlertToast")

    @if (!Model.Any())
    {
        <div class="panel">
            <div class="empty-panel">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z" stroke="#cbd5e1" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96" stroke="#cbd5e1" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                    <line x1="12" y1="22.08" x2="12" y2="12" stroke="#cbd5e1" stroke-width="1.6" stroke-linecap="round"/>
                </svg>
                <p>Your warehouse has no stock yet.</p>
                <a asp-controller="Inventory" asp-action="AddStock" class="btn-add-first">
                    <svg viewBox="0 0 16 16" width="13" height="13" fill="none"><path d="M8 1v14M1 8h14" stroke="#fff" stroke-width="2.2" stroke-linecap="round"/></svg>
                    Add your first stock
                </a>
            </div>
        </div>
    }
    else
    {
        int totalCount   = Model.Count;
        int healthyCount = Model.Count(i => !i.IsLowStock && i.Quantity > 0);
        int lowCount     = Model.Count(i => i.IsLowStock && i.Quantity > 0);
        int outCount     = Model.Count(i => i.Quantity == 0 && i.LowStockThreshold > 0);

        <div class="summary-strip">
            <div class="summary-chip chip-total">
                <span class="chip-dot"></span> @totalCount total products
            </div>
            <div class="summary-chip chip-healthy">
                <span class="chip-dot"></span> @healthyCount healthy
            </div>
            <div class="summary-chip chip-low">
                <span class="chip-dot"></span> @lowCount running low
            </div>
            <div class="summary-chip chip-out">
                <span class="chip-dot"></span> @outCount out of stock
            </div>
        </div>

        <div class="panel">
            <div class="panel-header">
                <p class="panel-title">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="3" y="3" width="7" height="7" rx="1" stroke="#475569" stroke-width="1.8"/>
                        <rect x="14" y="3" width="7" height="7" rx="1" stroke="#475569" stroke-width="1.8"/>
                        <rect x="3" y="14" width="7" height="7" rx="1" stroke="#475569" stroke-width="1.8"/>
                        <rect x="14" y="14" width="7" height="7" rx="1" stroke="#475569" stroke-width="1.8"/>
                    </svg>
                    Stock Levels
                </p>
                <span style="font-size:.75rem;color:#94a3b8;font-weight:600;">@totalCount items</span>
            </div>

            <table class="inv-table">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>SKU</th>
                        <th style="text-align:right">Quantity</th>
                        <th style="text-align:right">Alert Threshold</th>
                        <th style="text-align:center">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderBy(i => i.ProductName))
                    {
                        string rowClass = item.Quantity == 0 ? "row-out"
                                        : item.IsLowStock   ? "row-warn"
                                        : "";
                        string sbClass  = item.Quantity == 0 && item.LowStockThreshold > 0 ? "sb-out"
                                        : item.IsLowStock ? "sb-low"
                                        : "sb-ok";
                        string sbLabel  = item.Quantity == 0 && item.LowStockThreshold > 0 ? "Out of Stock"
                                        : item.IsLowStock ? "Low Stock"
                                        : "Healthy";

                        <tr class="@rowClass">
                            <td>
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId" class="prod-link">@item.ProductName</a>
                            </td>
                            <td><span class="badge-sku">@item.SKU</span></td>
                            <td style="text-align:right;font-weight:700;color:@(item.Quantity==0?"#ef4444":"#0f172a")">@item.Quantity</td>
                            <td style="text-align:right;color:#94a3b8;font-size:.82rem">@item.LowStockThreshold</td>
                            <td style="text-align:center">
                                <span class="status-badge @sbClass">@sbLabel</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>